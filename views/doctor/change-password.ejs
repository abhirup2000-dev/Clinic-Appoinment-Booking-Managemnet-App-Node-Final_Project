<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<%- include('../partials/toast') %>

<style>
  .pwd-container {
    min-height: calc(100vh - 76px);
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    padding: 40px 20px;
  }
  .pwd-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    padding: 40px;
    width: 100%;
    max-width: 450px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }
  .pwd-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 5px;
    background: linear-gradient(90deg, #ef4444, #f59e0b);
  }
  .pwd-icon {
    width: 70px;
    height: 70px;
    background: #fef2f2;
    color: #ef4444;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    margin-bottom: 24px;
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
  }
  .pwd-title {
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 8px;
    font-size: 24px;
  }
  .pwd-desc {
    color: #64748b;
    font-size: 14px;
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .form-control {
    padding: 14px 16px;
    border-radius: 10px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
  }
  .form-control:focus {
    background: #fff;
    border-color: #ef4444;
    box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1);
  }
  .btn-submit {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 14px;
    font-weight: 600;
    font-size: 16px;
    width: 100%;
    transition: all 0.3s ease;
    margin-top: 16px;
  }
  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
  }
</style>

<div class="pwd-container">
  <div class="pwd-card">
    <div class="pwd-icon">
      <i class="bi bi-shield-lock-fill"></i>
    </div>
    <h2 class="pwd-title">Action Required</h2>
    <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-dark p-3 rounded-3 mb-4">
      <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
      <strong>Security Policy:</strong> You are logging in with a temporary password. You must set a new secure password to continue.
    </div>

    <form id="pwdForm" onsubmit="handleChangePassword(event)">
      <div class="mb-3">
        <label class="form-label text-secondary fw-semibold small text-uppercase">New Password</label>
        <input type="password" class="form-control" id="newPassword" required minlength="6" placeholder="Enter new password">
      </div>
      <div class="mb-4">
        <label class="form-label text-secondary fw-semibold small text-uppercase">Confirm New Password</label>
        <input type="password" class="form-control" id="confirmPassword" required minlength="6" placeholder="Confirm new password">
      </div>

      <button type="submit" class="btn-submit" id="submitBtn">
        <span class="spinner-border spinner-border-sm d-none me-2" role="status" aria-hidden="true"></span>
        Update Password & Continue
      </button>
    </form>
  </div>
</div>

<script>
  async function handleChangePassword(e) {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    const spinner = btn.querySelector('.spinner-border');
    const pwd1 = document.getElementById('newPassword').value;
    const pwd2 = document.getElementById('confirmPassword').value;

    if (pwd1 !== pwd2) {
      return showToast("Passwords do not match", "error");
    }

    btn.disabled = true;
    spinner.classList.remove('d-none');

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          // We will use a special flag or the regular reset logic, but for now we'll 
          // update the profile via the profile endpoint since they are technically authenticated 
          // (forcePasswordResetMiddleware blocks api routes, but we can make an exception or use a dedicated endpoint)
          // Since the existing /reset-password requires a token, we should use /update-profile 
          // Wait, the user is logged in, so we can use a PUT to a dedicated endpoint or update profile
          // Let's assume we use the update-profile endpoint since they have a valid JWT cookie
          password: pwd1,
          isFirstLogin: false // Clear the flag
        })
      });
      
      // Because /update-profile expects form-data if there is a picture, let's use standard form data
      const formData = new FormData();
      formData.append('password', pwd1);
      formData.append('isFirstLogin', false);

      const profileRes = await fetch('/api/auth/update-profile', {
        method: 'PUT',
        body: formData // cookies are sent automatically
      });

      const data = await profileRes.json();

      if (data.success) {
        showToast("Password updated successfully!", "success");
        setTimeout(() => {
          window.location.href = '/doctor/dashboard';
        }, 1500);
      } else {
        showToast(data.message, "error");
        btn.disabled = false;
        spinner.classList.add('d-none');
      }
    } catch (err) {
      showToast("Failed to update password", "error");
      btn.disabled = false;
      spinner.classList.add('d-none');
    }
  }
</script>

<%- include('../partials/footer') %>
