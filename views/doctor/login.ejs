<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Doctor Portal Login</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    body {
      background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', sans-serif;
      padding: 20px;
    }

    .login-wrapper {
      width: 100%;
      max-width: 480px;
    }

    .login-card {
      border: none;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(79, 70, 229, 0.15);
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      padding: 50px 40px;
    }

    .brand-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .brand-icon {
      font-size: 40px;
      color: #4f46e5;
      margin-bottom: 15px;
      display: inline-block;
      background: rgba(79, 70, 229, 0.1);
      width: 80px;
      height: 80px;
      line-height: 80px;
      border-radius: 50%;
    }

    .form-control {
      height: 54px;
      border-radius: 14px;
      border: 1.5px solid #e2e8f0;
      padding-left: 20px;
      font-size: 15px;
      background: #f8fafc;
      transition: all 0.3s ease;
    }

    .form-control:focus {
      border-color: #4f46e5;
      background: #fff;
      box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
    }

    .btn-login {
      height: 54px;
      border-radius: 14px;
      font-weight: 600;
      font-size: 16px;
      background: linear-gradient(135deg, #4f46e5 0%, #3730a3 100%);
      border: none;
      color: white;
      transition: all 0.3s ease;
      margin-top: 10px;
    }

    .btn-login:hover {
      background: linear-gradient(135deg, #3730a3 0%, #312e81 100%);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
      color: white;
    }

    .form-label {
      font-weight: 600;
      color: #475569;
      margin-bottom: 8px;
    }
  </style>
</head>

<body>
  <%- include('../partials/flash') %>

  <div class="login-wrapper">
    <div class="card login-card">
      <div class="brand-header">
        <div class="brand-icon">
          <i class="bi bi-heart-pulse"></i>
        </div>
        <h2 class="fw-bold text-dark mb-2">CareConnect</h2>
        <p class="text-muted mb-0">Clinician Sign In</p>
      </div>

      <form action="/doctor/login" method="POST">
        <div class="mb-4">
          <label class="form-label">Clinician Email</label>
          <input type="email" name="email" class="form-control" placeholder="doctor@clinic.com" required>
        </div>

        <div class="mb-4">
          <label class="form-label">Secure Password</label>
          <input type="password" name="password" class="form-control" placeholder="••••••••" required>
        </div>

        <button type="submit" class="btn w-100 btn-login">
          Clinician Sign In <i class="bi bi-shield-lock ms-2"></i>
        </button>
      </form>
    </div>
    
    <div class="text-center mt-4 text-muted small fw-medium">
      © 2026 CareConnect Clinical Systems
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
