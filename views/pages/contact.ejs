<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us — CareConnect</title>
  <meta name="description" content="Get in touch with CareConnect Core Office. Contact support, query about clinic partnerships, or report general questions.">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    /* Custom Contact Styling */
    .contact-info-card {
      background: var(--cc-white);
      border: 1px solid var(--cc-slate-200);
      border-radius: var(--radius-lg);
      padding: 24px;
      display: flex;
      gap: 16px;
      align-items: flex-start;
      transition: all 0.3s var(--ease-smooth);
    }
    .contact-info-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
      border-color: var(--cc-emerald-light);
    }
    .contact-info-icon {
      width: 48px;
      height: 48px;
      border-radius: var(--radius-md);
      background: var(--cc-emerald-glow);
      color: var(--cc-emerald);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }
    .contact-form-container {
      background: var(--cc-white);
      border: 1px solid var(--cc-slate-200);
      border-radius: var(--radius-xl);
      padding: 40px;
      box-shadow: var(--shadow-lg);
    }
    .form-floating > .form-control:focus ~ label::after, 
    .form-floating > .form-control-plaintext:focus ~ label::after {
      background-color: transparent !important;
    }
    .form-control:focus {
      border-color: var(--cc-emerald);
      box-shadow: 0 0 0 4px var(--cc-emerald-glow);
    }
  </style>
</head>
<body>
  <%- include('../partials/flash') %>

  <%- include('../partials/navbar', { activePage: 'contact' }) %>

  <!-- Page Header -->
  <section class="cc-page-header">
    <div class="container position-relative" style="z-index:2;">
      <div class="cc-breadcrumb">
        <a href="/">Home</a>
        <i class="bi bi-chevron-right" style="font-size:11px;"></i>
        <span>Contact</span>
      </div>
      <h1 class="mb-3">Get In Touch</h1>
      <p>Have inquiries regarding clinic onboarding, clinician profiles, or need general technical support? We are here to assist.</p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="cc-section">
    <div class="container">
      <div class="row g-5">
        <!-- Contact Information -->
        <div class="col-lg-5 cc-fade-left">
          <span class="cc-badge cc-badge-emerald mb-3"><i class="bi bi-geo-alt"></i> Information</span>
          <h2 class="cc-section-title mb-4" style="font-size:32px;">Core Office Details</h2>
          <p class="mb-5" style="color:var(--cc-slate-500); line-height:1.7;">
            Our physical administration and billing offices are headquartered in Salt Lake City, Sector 1. Stop by for clinical partnership queries or schedule a support consultation.
          </p>

          <div class="d-flex flex-column gap-4">
            <!-- Office Address -->
            <div class="contact-info-card">
              <div class="contact-info-icon">
                <i class="bi bi-building"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1" style="color:var(--cc-slate-900);">Headquarters Address</h6>
                <p class="small mb-0 text-muted" style="line-height:1.6;">
                  102 Care Plaza, Sector 1, Salt Lake City Bypass, Kolkata, West Bengal 700091
                </p>
              </div>
            </div>

            <!-- Phones -->
            <div class="contact-info-card">
              <div class="contact-info-icon" style="background:var(--cc-indigo-glow); color:var(--cc-indigo);">
                <i class="bi bi-telephone-fill"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1" style="color:var(--cc-slate-900);">Call Support</h6>
                <p class="small mb-0 text-muted" style="line-height:1.6;">
                  Support Line: +91 (033) 2468 1357<br>
                  Cell: +91 98765 43210
                </p>
              </div>
            </div>

            <!-- Emails -->
            <div class="contact-info-card">
              <div class="contact-info-icon" style="background:rgba(59, 130, 246, 0.1); color:var(--cc-info);">
                <i class="bi bi-envelope-at-fill"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1" style="color:var(--cc-slate-900);">Email Communications</h6>
                <p class="small mb-0 text-muted" style="line-height:1.6;">
                  General: support@careconnect.com<br>
                  Partnerships: partner@careconnect.com
                </p>
              </div>
            </div>

            <!-- Hours -->
            <div class="contact-info-card">
              <div class="contact-info-icon" style="background:rgba(245, 158, 11, 0.1); color:var(--cc-warning);">
                <i class="bi bi-clock-fill"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1" style="color:var(--cc-slate-900);">Operational Hours</h6>
                <p class="small mb-0 text-muted" style="line-height:1.6;">
                  Monday – Saturday: 8:00 AM – 9:00 PM<br>
                  Sunday: Emergency On-Call Only
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="col-lg-7 cc-fade-right">
          <div class="contact-form-container">
            <span class="cc-badge cc-badge-indigo mb-3"><i class="bi bi-chat-left-text"></i> Message Us</span>
            <h3 class="fw-bold mb-4" style="color:var(--cc-slate-900);">Submit a Support Ticket</h3>
            
            <form id="supportForm" onsubmit="handleSupportSubmit(event)">
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" id="contactName" placeholder="John Doe" required style="border-radius:var(--radius-md);">
                    <label for="contactName"><i class="bi bi-person me-1"></i> Full Name</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="contactEmail" placeholder="name@example.com" required style="border-radius:var(--radius-md);">
                    <label for="contactEmail"><i class="bi bi-envelope me-1"></i> Email Address</label>
                  </div>
                </div>
              </div>

              <div class="form-floating mb-3">
                <input type="text" class="form-control" id="contactSubject" placeholder="Billing Inquiry" required style="border-radius:var(--radius-md);">
                <label for="contactSubject"><i class="bi bi-patch-question me-1"></i> Subject</label>
              </div>

              <div class="form-floating mb-4">
                <textarea class="form-control" placeholder="Write your query here..." id="contactMessage" style="height: 150px; border-radius:var(--radius-md);"></textarea>
                <label for="contactMessage"><i class="bi bi-pencil me-1"></i> How can we help?</label>
              </div>

              <button type="submit" class="btn btn-cc-primary btn-lg w-100 py-3" style="border-radius:var(--radius-md);">
                <i class="bi bi-send-fill me-2"></i> Send Message
              </button>
            </form>

            <div id="formFeedback" class="mt-4 text-center d-none">
              <div class="alert alert-success d-flex align-items-center justify-content-center gap-2" role="alert" style="border-radius:var(--radius-md);">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>Your query has been logged! Our support team will reach out within 2 hours.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Map Block -->
  <section class="cc-section cc-section-alt p-0" style="height: 400px; position:relative; overflow:hidden;">
    <div class="position-absolute w-100 h-100" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.08), rgba(16, 185, 129, 0.08)); z-index:1;"></div>
    <div class="container h-100 d-flex align-items-center justify-content-center position-relative" style="z-index:2;">
      <div class="text-center p-5 bg-white border border-slate-200" style="border-radius:var(--radius-xl); box-shadow:var(--shadow-xl); max-width:540px;">
        <i class="bi bi-map-fill text-emerald mb-3" style="font-size:48px; display:inline-block;"></i>
        <h4 class="fw-bold mb-2" style="color:var(--cc-slate-900);">Location Audited</h4>
        <p class="small text-muted mb-3" style="line-height:1.6;">
          Our office sits in the technology hub of Sector 1 Salt Lake, highly accessible via VIP road and central bypass metro networks.
        </p>
        <button class="btn btn-cc-outline btn-sm px-4" onclick="window.open('https://maps.google.com', '_blank')">
          <i class="bi bi-cursor-fill me-1"></i> Open Google Maps
        </button>
      </div>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <%- include('../partials/chat-widget') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.cc-fade-up, .cc-fade-left, .cc-fade-right').forEach(el => observer.observe(el));

    // Handle Form Submit
    function handleSupportSubmit(e) {
      e.preventDefault();
      
      const form = document.getElementById('supportForm');
      const feedback = document.getElementById('formFeedback');
      
      // Hide form fields & show feedback
      form.classList.add('d-none');
      feedback.classList.remove('d-none');
      
      // Focus on feedback alert
      feedback.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  </script>
</body>
</html>
