<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Live Chat — CareConnect</title>
  <meta name="description" content="Chat live with your doctor on CareConnect.">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Socket.io -->
  <script src="/socket.io/socket.io.js"></script>

  <style>
    :root {
      --primary: #4f46e5;
      --primary-light: #818cf8;
      --accent: #10b981;
      --bg: #f1f5f9;
      --card: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --border: #e2e8f0;
      --radius: 14px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ===== CHAT TOPBAR ===== */
    .chat-topbar {
      background: #fff;
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 66px;
      display: flex;
      align-items: center;
      gap: 16px;
      flex-shrink: 0;
      box-shadow: 0 1px 0 var(--border);
    }

    .back-btn {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: var(--muted);
      font-size: 17px;
      flex-shrink: 0;
      transition: all 0.2s;
    }

    .back-btn:hover {
      background: #e2e8f0;
      color: var(--text);
    }

    .doctor-info {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1;
    }

    .doc-avatar-wrap {
      position: relative;
      flex-shrink: 0;
    }

    .doc-avatar {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--border);
    }

    .status-indicator {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #94a3b8;
      border: 2px solid #fff;
      position: absolute;
      bottom: 1px;
      right: 1px;
      transition: background 0.3s;
    }

    .status-indicator.online {
      background: var(--accent);
    }

    .doc-name-label {
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.2;
    }

    .doc-status-label {
      font-size: 12px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 5px;
      margin-top: 2px;
    }

    .topbar-brand {
      font-size: 15px;
      font-weight: 800;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
    }

    .topbar-brand i {
      color: var(--accent);
    }

    /* ===== CHAT BODY ===== */
    .chat-body {
      flex: 1;
      overflow-y: auto;
      padding: 24px 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      background: var(--bg);
    }

    /* Date divider */
    .date-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 8px 0;
    }

    .date-divider hr {
      flex: 1;
      border-color: var(--border);
      margin: 0;
    }

    .date-divider span {
      font-size: 11px;
      font-weight: 600;
      color: var(--muted);
      white-space: nowrap;
      background: var(--bg);
      padding: 0 4px;
    }

    /* Message bubbles */
    .msg-row {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      max-width: 72%;
      animation: msgIn 0.2s ease;
    }

    @keyframes msgIn {
      from {
        opacity: 0;
        transform: translateY(6px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .msg-row.sent {
      align-self: flex-end;
      flex-direction: row-reverse;
    }

    .msg-row.received {
      align-self: flex-start;
    }

    .msg-avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      border: 2px solid var(--border);
    }

    .msg-bubble {
      padding: 11px 16px;
      border-radius: 18px;
      font-size: 14px;
      line-height: 1.55;
      word-break: break-word;
      position: relative;
    }

    .sent .msg-bubble {
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: #fff;
      border-bottom-right-radius: 4px;
    }

    .received .msg-bubble {
      background: #fff;
      color: var(--text);
      border: 1px solid var(--border);
      border-bottom-left-radius: 4px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .msg-time {
      font-size: 11px;
      color: var(--muted);
      margin-top: 3px;
      padding: 0 4px;
    }

    .sent .msg-time {
      text-align: right;
    }

    /* File message */
    .file-bubble {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: #fff;
      text-decoration: none;
      color: var(--text);
      font-size: 13px;
      transition: background 0.15s;
    }

    .file-bubble:hover {
      background: var(--bg);
    }

    .sent .file-bubble {
      background: rgba(255, 255, 255, 0.15);
      border-color: rgba(255, 255, 255, 0.2);
      color: #fff;
    }

    /* ===== TYPING INDICATOR ===== */
    .typing-row {
      display: flex;
      align-items: center;
      gap: 8px;
      align-self: flex-start;
      animation: msgIn 0.2s ease;
    }

    .typing-bubble {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 18px;
      border-bottom-left-radius: 4px;
      padding: 12px 16px;
      display: flex;
      gap: 5px;
    }

    .typing-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #94a3b8;
      animation: typeBounce 1.4s infinite ease-in-out both;
    }

    .typing-dot:nth-child(1) {
      animation-delay: -0.32s;
    }

    .typing-dot:nth-child(2) {
      animation-delay: -0.16s;
    }

    @keyframes typeBounce {

      0%,
      80%,
      100% {
        transform: scale(0.6);
        opacity: 0.4;
      }

      40% {
        transform: scale(1);
        opacity: 1;
      }
    }

    /* ===== INPUT BAR ===== */
    .chat-input-bar {
      background: #fff;
      border-top: 1px solid var(--border);
      padding: 14px 20px;
      flex-shrink: 0;
    }

    .input-row {
      display: flex;
      align-items: center;
      gap: 10px;
      max-width: 900px;
      margin: 0 auto;
    }

    .file-btn {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 17px;
      color: var(--muted);
      transition: all 0.2s;
      flex-shrink: 0;
    }

    .file-btn:hover {
      background: var(--border);
      color: var(--text);
    }

    .msg-input {
      flex: 1;
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 11px 20px;
      font-size: 14px;
      font-family: 'Inter', sans-serif;
      color: var(--text);
      background: var(--bg);
      outline: none;
      transition: all 0.2s;
      resize: none;
      max-height: 120px;
      line-height: 1.4;
    }

    .msg-input:focus {
      border-color: var(--primary);
      background: #fff;
      box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
    }

    .send-btn {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: none;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 17px;
      cursor: pointer;
      flex-shrink: 0;
      transition: all 0.2s;
    }

    .send-btn:hover {
      transform: scale(1.08);
      box-shadow: 0 4px 16px rgba(79, 70, 229, 0.35);
    }

    .send-btn:disabled {
      background: #cbd5e1;
      transform: none;
      box-shadow: none;
      cursor: not-allowed;
    }

    /* ===== EMPTY STATE ===== */
    .chat-empty {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      gap: 12px;
      text-align: center;
      padding: 40px;
    }

    .chat-empty i {
      font-size: 52px;
      color: #cbd5e1;
    }

    .chat-empty p {
      font-size: 14px;
      max-width: 280px;
    }

    /* ===== CONNECTION BANNER ===== */
    .conn-banner {
      background: #fef3c7;
      border-bottom: 1px solid #fde68a;
      padding: 8px 24px;
      font-size: 12px;
      font-weight: 600;
      color: #92400e;
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    /* ===== TOAST ===== */
    #toast-container {
      position: fixed;
      bottom: 80px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .toast-msg {
      background: var(--text);
      color: #fff;
      padding: 11px 18px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
      animation: toastIn 0.25s ease;
    }

    .toast-msg.error {
      background: #dc2626;
    }

    .toast-msg.success {
      background: #059669;
    }

    .toast-msg.info {
      background: #4f46e5;
    }

    @keyframes toastIn {
      from {
        transform: translateX(30px);
        opacity: 0;
      }

      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    @media (max-width: 600px) {
      .msg-row {
        max-width: 90%;
      }

      .chat-topbar {
        padding: 0 14px;
      }

      .chat-input-bar {
        padding: 10px 14px;
      }
    }
  </style>
</head>

<body>
  <%- include('../partials/flash') %>

  <!-- ===== TOPBAR ===== -->
  <header class="chat-topbar">
    <a href="/patient/dashboard#appointments" class="back-btn" title="Back to Dashboard">
      <i class="bi bi-arrow-left"></i>
    </a>

    <div class="doctor-info">
      <div class="doc-avatar-wrap">
        <img id="doctorAvatar" src="https://ui-avatars.com/api/?name=Doctor&background=4f46e5&color=fff&size=80"
          alt="Doctor" class="doc-avatar">
        <div class="status-indicator" id="statusDot"></div>
      </div>
      <div>
        <div class="doc-name-label" id="doctorName">Loading…</div>
        <div class="doc-status-label">
          <span id="statusText" style="color:#94a3b8;">Connecting…</span>
        </div>
      </div>
    </div>

    <a href="/" class="topbar-brand d-none d-sm-flex">
      <i class="bi bi-heart-pulse-fill"></i> CareConnect
    </a>
  </header>

  <!-- Connection banner (hidden when connected) -->
  <div class="conn-banner d-none" id="connBanner">
    <i class="bi bi-wifi-off"></i> Connecting to chat server…
  </div>

  <!-- ===== CHAT BODY ===== -->
  <div class="chat-body" id="chatBody">
    <div class="chat-empty" id="chatEmpty">
      <i class="bi bi-chat-text"></i>
      <p>Loading your conversation…</p>
    </div>
  </div>

  <!-- ===== INPUT BAR ===== -->
  <div class="chat-input-bar">
    <div class="input-row">
      <label class="file-btn" for="fileInput" title="Send file">
        <i class="bi bi-paperclip"></i>
        <input type="file" id="fileInput" style="display:none;" accept="image/*,.pdf,.doc,.docx">
      </label>

      <textarea class="msg-input" id="msgInput" placeholder="Type your message…" rows="1" disabled></textarea>

      <button class="send-btn" id="sendBtn" disabled>
        <i class="bi bi-send-fill"></i>
      </button>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast-container"></div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Configuration
    const appointmentId = "<%= appointmentId %>";
    let socket;
    let currentUser = null;
    let doctorId = null;
    let typingTimeout = null;
    let isConnected = false;
    let historyCleaned = false;

    // Init
    async function init() {
      try {
        // 1. Get current user profile
        const profileRes = await fetch('/api/auth/profile');
        const profileData = await profileRes.json();
        if (!profileData.success) throw new Error('Profile fetch failed');
        currentUser = profileData.data;

        // 2. Get appointment details (doctor info)
        const apptRes = await fetch(`/api/appointments/${appointmentId}`);
        const apptData = await apptRes.json();
        if (!apptData.success) throw new Error('Appointment fetch failed');

        const appt = apptData.data;
        doctorId = appt.doctor._id;

        // Populate topbar
        document.getElementById('doctorName').textContent = `Dr. ${appt.doctor.name}`;
        document.getElementById('doctorAvatar').src =
          appt.doctor.profilePicture ||
          `https://ui-avatars.com/api/?name=${encodeURIComponent(appt.doctor.name)}&background=4f46e5&color=fff&size=80`;

        // 3. Connect socket
        connectSocket();

        // 4. Load chat history
        await loadHistory();

      } catch (err) {
        console.error(err);
        toast('Failed to load chat. Please try refreshing.', 'error');
        document.getElementById('chatEmpty').innerHTML = `
          <i class="bi bi-exclamation-triangle" style="color:#fbbf24;"></i>
          <p>Could not load this chat. Make sure your session is valid.</p>
        `;
      }
    }


    //  Socket.io

    function connectSocket() {
      document.getElementById('connBanner').classList.remove('d-none');

      socket = io({
        auth: {
          token: getCookie('patientAccessToken'),
          userId: currentUser._id,
          role: currentUser.role
        }
      });

      socket.on('connect', () => {
        isConnected = true;
        document.getElementById('connBanner').classList.add('d-none');
        document.getElementById('msgInput').disabled = false;
        document.getElementById('sendBtn').disabled = true;
        socket.emit('join-chat-room', appointmentId);
      });

      socket.on('connect_error', (error) => {
        console.error('Socket connection error:', error);
        document.getElementById('connBanner').classList.remove('d-none');
      });

      socket.on('disconnect', () => {
        isConnected = false;
        document.getElementById('connBanner').classList.remove('d-none');
        document.getElementById('statusDot').classList.remove('online');
        document.getElementById('statusText').textContent = 'Offline';
        document.getElementById('statusText').style.color = '#94a3b8';
      });

      socket.on('receive-chat-message', (msg) => {
        const isMine = msg.sender === currentUser._id || msg.senderId === currentUser._id;
        if (!isMine) {
          appendMessage(msg, false);
          playNotificationSound();
        }
      });

      socket.on('user-typing', ({ senderId }) => {
        if (senderId !== currentUser._id) showTyping();
      });

      socket.on('user-stop-typing', ({ senderId }) => {
        if (senderId !== currentUser._id) removeTyping();
      });

      socket.on('presence-update', (onlineUsers) => {
        const online = Array.isArray(onlineUsers) && onlineUsers.includes(doctorId);
        document.getElementById('statusDot').classList.toggle('online', online);
        document.getElementById('statusText').textContent = online ? 'Online' : 'Offline';
        document.getElementById('statusText').style.color = online ? '#10b981' : '#94a3b8';
      });
    }

    //  Chat History
    async function loadHistory() {
      try {
        const res = await fetch(`/api/live-chat/${appointmentId}`, {
          headers: {
            'Authorization': `Bearer ${getCookie('patientAccessToken')}`
          }
        });
        const data = await res.json();

        const body = document.getElementById('chatBody');
        body.innerHTML = ''; // clear

        if (data.success && data.data && data.data.length > 0) {
          let lastDate = null;
          data.data.forEach(msg => {
            const msgDate = new Date(msg.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
            if (msgDate !== lastDate) {
              insertDateDivider(msgDate);
              lastDate = msgDate;
            }
            const isMine = msg.sender === currentUser._id;
            appendMessage(msg, isMine, false); // false = no scroll on each msg
          });
          scrollBottom();
        } else {
          body.innerHTML = `
            <div class="chat-empty">
              <i class="bi bi-chat-text"></i>
              <p>No messages yet. Send a message to start the conversation!</p>
            </div>
          `;
        }
      } catch (err) {
        console.error('History load error:', err);
        toast('Failed to load chat history', 'error');
      }
    }

    //  Message Rendering
    function appendMessage(msg, isMine, scroll = true) {
      const body = document.getElementById('chatBody');

      // Remove empty state if present
      const emptyState = body.querySelector('.chat-empty');
      if (emptyState) emptyState.remove();

      // Remove typing indicator
      removeTyping();

      const time = new Date(msg.createdAt || Date.now()).toLocaleTimeString([], {
        hour: '2-digit', minute: '2-digit'
      });

      const avatarSrc = isMine
        ? (currentUser.profilePicture || `https://ui-avatars.com/api/?name=${encodeURIComponent(currentUser.name)}&background=4f46e5&color=fff&size=80`)
        : (document.getElementById('doctorAvatar').src);

      let contentHtml = '';
      if (msg.messageType === 'file' && msg.fileUrl) {
        const isImage = /\.(png|jpg|jpeg|gif|webp)$/i.test(msg.fileUrl);
        if (isImage) {
          contentHtml = `
            <div class="msg-bubble">
              <img src="${msg.fileUrl}" alt="Sent image" style="max-width:220px;border-radius:10px;display:block;">
            </div>
          `;
        } else {
          contentHtml = `
            <div class="msg-bubble" style="padding:0;border:none;background:none;">
              <a href="${msg.fileUrl}" target="_blank" class="file-bubble">
                <i class="bi bi-file-earmark-fill" style="font-size:20px;color:#4f46e5;"></i>
                <span>${escapeHtml(msg.fileName || 'File')}</span>
                <i class="bi bi-download ms-auto" style="font-size:14px;color:var(--muted);"></i>
              </a>
            </div>
          `;
        }
      } else {
        contentHtml = `<div class="msg-bubble">${escapeHtml(msg.content)}</div>`;
      }

      const row = document.createElement('div');
      row.className = `msg-row ${isMine ? 'sent' : 'received'}`;
      row.innerHTML = `
        <img src="${avatarSrc}" alt="${isMine ? 'Me' : 'Doctor'}" class="msg-avatar">
        <div>
          ${contentHtml}
          <div class="msg-time">${time}</div>
        </div>
      `;

      body.appendChild(row);
      if (scroll) scrollBottom();
    }

    function insertDateDivider(dateStr) {
      const body = document.getElementById('chatBody');
      const div = document.createElement('div');
      div.className = 'date-divider';
      div.innerHTML = `<hr><span>${dateStr}</span><hr>`;
      body.appendChild(div);
    }

    function scrollBottom() {
      const body = document.getElementById('chatBody');
      body.scrollTop = body.scrollHeight;
    }

    //  Typing Indicator
    function showTyping() {
      if (document.getElementById('typingIndicator')) return;
      const body = document.getElementById('chatBody');
      const row = document.createElement('div');
      row.id = 'typingIndicator';
      row.className = 'typing-row';
      row.innerHTML = `
        <img src="${document.getElementById('doctorAvatar').src}" alt="Doctor" class="msg-avatar">
        <div class="typing-bubble">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      `;
      body.appendChild(row);
      scrollBottom();
    }

    function removeTyping() {
      const el = document.getElementById('typingIndicator');
      if (el) el.remove();
    }

    // Send Message
    const msgInput = document.getElementById('msgInput');
    const sendBtn = document.getElementById('sendBtn');

    msgInput.addEventListener('input', () => {
      sendBtn.disabled = msgInput.value.trim().length === 0;

      // Auto-resize textarea
      msgInput.style.height = 'auto';
      msgInput.style.height = Math.min(msgInput.scrollHeight, 120) + 'px';

      if (!socket) return;
      socket.emit('typing', { appointmentId, senderId: currentUser._id });
      clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        socket.emit('stop-typing', { appointmentId, senderId: currentUser._id });
      }, 1000);
    });

    msgInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (!sendBtn.disabled) sendMessage();
      }
    });

    sendBtn.addEventListener('click', sendMessage);

    function sendMessage() {
      const content = msgInput.value.trim();
      if (!content || !socket) return;

      // Optimistic UI — show immediately
      appendMessage({
        content,
        sender: currentUser._id,
        createdAt: new Date().toISOString(),
        messageType: 'text'
      }, true);

      // Persist to database via API
      fetch(`/patient/live-chat/${appointmentId}/send`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${getCookie('patientAccessToken')}`
        },
        body: JSON.stringify({
          content,
          messageType: 'text'
        })
      }).catch(err => {
        console.error('Failed to persist message:', err);
        toast('Failed to send message. Please try again.', 'error');
      });

      // Emit socket event for real-time delivery
      socket.emit('send-chat-message', {
        appointmentId,
        senderId: currentUser._id,
        sender: currentUser._id,
        receiverId: doctorId,
        content,
        messageType: 'text',
        createdAt: new Date().toISOString()
      });

      msgInput.value = '';
      msgInput.style.height = 'auto';
      sendBtn.disabled = true;
      socket.emit('stop-typing', { appointmentId, senderId: currentUser._id });
    }

    //  File Upload
    document.getElementById('fileInput').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      toast('Uploading file…', 'info');

      try {
        const formData = new FormData();
        formData.append('file', file);

        const res = await fetch(`/patient/live-chat/${appointmentId}/upload`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${getCookie('patientAccessToken')}`
          },
          body: formData
        });
        const data = await res.json();

        if (!data.success) throw new Error('Upload failed');

        // Optimistic UI
        appendMessage({
          fileUrl: data.fileUrl,
          fileName: data.fileName,
          sender: currentUser._id,
          createdAt: new Date().toISOString(),
          messageType: 'file'
        }, true);

        // Notify via socket
        socket.emit('send-chat-message', {
          appointmentId,
          senderId: currentUser._id,
          sender: currentUser._id,
          receiverId: doctorId,
          content: '',
          messageType: 'file',
          fileUrl: data.fileUrl,
          fileName: data.fileName,
          createdAt: new Date().toISOString()
        });

        toast('File sent!', 'success');
      } catch (err) {
        toast('File upload failed.', 'error');
        console.error(err);
      }

      e.target.value = '';
    });


    //Utils
    function getCookie(name) {
      const v = `; ${document.cookie}`;
      const p = v.split(`; ${name}=`);
      if (p.length === 2) return p.pop().split(';').shift();
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;')
        .replace(/\n/g, '<br>');
    }

    function toast(msg, type = 'info') {
      const c = document.getElementById('toast-container');
      const el = document.createElement('div');
      el.className = `toast-msg ${type}`;
      const icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', info: 'bi-info-circle-fill' };
      el.innerHTML = `<i class="bi ${icons[type] || icons.info}"></i> ${msg}`;
      c.appendChild(el);
      setTimeout(() => el.remove(), 4000);
    }

    function playNotificationSound() {
      try {
        const audio = new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3');
        audio.play().catch(e => console.log('Audio play failed:', e));
      } catch (e) { }
    }

    //  Boot
    init();
  </script>
</body>

</html>