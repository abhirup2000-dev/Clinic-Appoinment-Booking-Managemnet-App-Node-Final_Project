<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patient Portal Login</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    body {
      background: linear-gradient(135deg, #f0fdf4 0%, #e0f2fe 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', sans-serif;
      padding: 20px;
    }

    .login-wrapper {
      width: 100%;
      max-width: 480px;
    }

    .login-card {
      border: none;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(16, 185, 129, 0.15);
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      padding: 50px 40px;
    }

    .brand-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .brand-icon {
      font-size: 40px;
      color: #10b981;
      margin-bottom: 15px;
      display: inline-block;
      background: rgba(16, 185, 129, 0.1);
      width: 80px;
      height: 80px;
      line-height: 80px;
      border-radius: 50%;
    }

    .form-control {
      height: 54px;
      border-radius: 14px;
      border: 1.5px solid #e2e8f0;
      padding-left: 20px;
      font-size: 15px;
      background: #f8fafc;
      transition: all 0.3s ease;
    }

    .form-control:focus {
      border-color: #10b981;
      background: #fff;
      box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
    }

    .btn-login {
      height: 54px;
      border-radius: 14px;
      font-weight: 600;
      font-size: 16px;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border: none;
      color: white;
      transition: all 0.3s ease;
      margin-top: 10px;
    }

    .btn-login:hover {
      background: linear-gradient(135deg, #059669 0%, #047857 100%);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
      color: white;
    }

    .form-label {
      font-weight: 600;
      color: #475569;
      margin-bottom: 8px;
    }
    
    .register-link {
      color: #10b981;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }
    
    .register-link:hover {
      color: #059669;
      text-decoration: underline;
    }
  </style>
</head>

<body>
  <%- include('../partials/flash') %>

  <div class="login-wrapper">
    <div class="card login-card">
      <div class="brand-header">
        <div class="brand-icon">
          <i class="bi bi-heart-pulse-fill"></i>
        </div>
        <h2 class="fw-bold text-dark mb-2">CareConnect</h2>
        <p class="text-muted mb-0">Patient Sign In</p>
      </div>

      <form action="/patient/login" method="POST">
        <div class="mb-4">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control" placeholder="patient@example.com" required>
        </div>

        <div class="mb-4">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="••••••••" required>
        </div>

        <button type="submit" class="btn w-100 btn-login">
          Access Portal <i class="bi bi-arrow-right ms-2"></i>
        </button>

        <div class="text-center mt-4">
          <p class="mb-0 text-muted">
            New patient here?
            <a href="/patient/register-view" class="register-link">Register Account</a>
          </p>
        </div>
      </form>
    </div>
    
    <div class="text-center mt-4 text-muted small fw-medium">
      © 2026 CareConnect Systems
    </div>
  </div>

  <!-- OTP Modal -->
  <div class="modal fade" id="otpModal" tabindex="-1" aria-labelledby="otpModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 15px 35px rgba(0,0,0,0.1);">
        <div class="modal-header border-0 pb-0 justify-content-center mt-4">
          <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
            <i class="bi bi-shield-lock text-success" style="font-size: 30px;"></i>
          </div>
        </div>
        <div class="modal-body text-center px-5 pt-3 pb-5">
          <h4 class="fw-bold mb-2">Verify Your Email</h4>
          <p class="text-muted mb-4 small">An OTP has been sent to your email address. Please enter it below to verify your account.</p>
          
          <form action="/patient/verify-otp" method="POST" id="otpForm">
            <input type="hidden" name="email" id="verifyEmail" value="<%= typeof requiresVerification !== 'undefined' ? requiresVerification : '' %>">
            
            <div class="mb-4">
              <input type="text" name="otp" class="form-control form-control-lg text-center fw-bold" placeholder="Enter 6-digit OTP" required maxlength="6" style="letter-spacing: 5px; font-size: 20px;">
            </div>
            
            <button type="submit" class="btn btn-success w-100 py-3 rounded-3 fw-bold shadow-sm">
              Verify Account
            </button>
          </form>
          
          <div class="mt-4">
            <form action="/api/auth/resend-otp" method="POST" id="resendOtpForm">
              <input type="hidden" name="email" value="<%= typeof requiresVerification !== 'undefined' ? requiresVerification : '' %>">
              <button type="button" class="btn btn-link text-success text-decoration-none p-0 fw-semibold" onclick="document.getElementById('resendOtpForm').submit()">
                Resend OTP
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    // Auto-open OTP modal if requiresVerification is set
    <% if (typeof requiresVerification !== 'undefined' && requiresVerification.length > 0) { %>
      document.addEventListener('DOMContentLoaded', function() {
        var myModal = new bootstrap.Modal(document.getElementById('otpModal'));
        myModal.show();
      });
    <% } %>
  </script>
</body>

</html>
