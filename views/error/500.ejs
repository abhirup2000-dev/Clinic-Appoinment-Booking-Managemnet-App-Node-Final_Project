<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500 Internal Error - CareConnect</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: #f8fafc;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0;
    }
    .error-container {
      text-align: center;
      padding: 40px;
      max-width: 600px;
    }
    .error-code {
      font-size: 120px;
      font-weight: 800;
      background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1;
      margin-bottom: 20px;
    }
    .error-title {
      font-size: 24px;
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 16px;
    }
    .error-text {
      color: #64748b;
      font-size: 16px;
      margin-bottom: 32px;
      line-height: 1.6;
    }
    .error-details {
      background: #fee2e2;
      color: #991b1b;
      padding: 16px;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 32px;
      text-align: left;
      font-family: monospace;
      word-break: break-all;
    }
    .btn-home {
      background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
      border: none;
      border-radius: 50px;
      padding: 12px 32px;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    .btn-home:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(239, 68, 68, 0.2);
    }
  </style>
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="error-container">
    <div class="error-code">500</div>
    <div class="error-title">Internal Server Error</div>
    <div class="error-text">
      Something went wrong on our end. Our engineers have been notified and are working to fix the issue.
    </div>
    
    <% if (locals.error) { %>
      <div class="error-details">
        <strong>Error Details:</strong><br>
        <%= error %>
      </div>
    <% } %>

    <a href="/" class="btn btn-primary btn-home">
      Return to Homepage
    </a>
  </div>
</body>
</html>
