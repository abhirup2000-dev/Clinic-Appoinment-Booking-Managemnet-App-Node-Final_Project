<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CareConnect — Premium Healthcare Portal</title>
  <meta name="description" content="Experience seamless doctor appointments, verified clinic facilities, and personalized clinical checkup reviews at your convenience.">
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Premium Stylesheet -->
  <link rel="stylesheet" href="/css/main.css">
  
  <style>
    /* Carousel styling */
    .carousel-item {
      height: 600px;
      min-height: 450px;
      background: no-repeat center center;
      background-size: cover;
    }
    .carousel-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to right, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0.4) 100%);
    }
    .carousel-caption {
      text-align: left;
      top: 25%;
      left: 8%;
      right: 8%;
      bottom: auto;
    }
    .carousel-caption h1 {
      font-size: 56px;
      font-weight: 800;
      letter-spacing: -1.5px;
      margin-bottom: 20px;
      color: var(--cc-white);
    }
    .carousel-caption p {
      font-size: 19px;
      max-width: 600px;
      margin-bottom: 32px;
      opacity: 0.9;
      color: var(--cc-slate-200);
      line-height: 1.6;
    }
    @media (max-width: 768px) {
      .carousel-item { height: 480px; }
      .carousel-caption { top: 15%; left: 5%; right: 5%; }
      .carousel-caption h1 { font-size: 32px; }
      .carousel-caption p { font-size: 15px; }
    }
  </style>
</head>
<body>
  <%- include('partials/flash') %>

  <%- include('partials/navbar', { activePage: 'home' }) %>

  <!-- Banner Carousel Hero Section -->
  <section id="home">
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
      <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
      </div>

      <div class="carousel-inner">
        <!-- Slide 1 -->
        <div class="carousel-item active" style="background-image: url('https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&w=1200&q=80');">
          <div class="carousel-overlay"></div>
          <div class="container position-relative h-100">
            <div class="carousel-caption cc-fade-left visible">
              <span class="cc-badge cc-badge-emerald mb-3"><i class="bi bi-hospital"></i> Premium Clinical Spaces</span>
              <h1>Your Partner in Healthcare</h1>
              <p>Experience seamless doctor appointments, verified clinic facilities, and personalized clinical checkup reviews at your convenience.</p>
              <a href="/patient/login-view" class="btn btn-cc-primary btn-lg px-4 py-2.5 mt-2 fs-6">
                Start Consultation Now <i class="bi bi-arrow-right ms-2"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Slide 2 -->
        <div class="carousel-item" style="background-image: url('https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&w=1200&q=80');">
          <div class="carousel-overlay"></div>
          <div class="container position-relative h-100">
            <div class="carousel-caption">
              <span class="cc-badge cc-badge-indigo mb-3"><i class="bi bi-activity"></i> Advanced Diagnostics</span>
              <h1>Modern Equipment & Certified Care</h1>
              <p>Connect with highly qualified medical practitioners. Review detailed summaries of consultation queues, prescription archives, and symptoms checkups.</p>
              <a href="/patient/login-view" class="btn btn-cc-primary btn-lg px-4 py-2.5 mt-2 fs-6">
                Book Verified Specialist <i class="bi bi-arrow-right ms-2"></i>
              </a>
            </div>
          </div>
        </div>
      </div>

      <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
      </button>
    </div>
  </section>

  <!-- Stats Bar -->
  <section style="background: var(--cc-white); margin-top:-40px; position:relative; z-index:3;">
    <div class="container">
      <div class="row g-0" style="background:var(--cc-white); border-radius:var(--radius-xl); box-shadow:var(--shadow-lg); overflow:hidden;">
        <div class="col-md-3 cc-stat" style="border-right:1px solid var(--cc-slate-200);">
          <div class="cc-stat-number">15+</div>
          <div class="cc-stat-label">Verified Clinics</div>
        </div>
        <div class="col-md-3 cc-stat" style="border-right:1px solid var(--cc-slate-200);">
          <div class="cc-stat-number">50+</div>
          <div class="cc-stat-label">Specialist Doctors</div>
        </div>
        <div class="col-md-3 cc-stat" style="border-right:1px solid var(--cc-slate-200);">
          <div class="cc-stat-number">10k+</div>
          <div class="cc-stat-label">Checked Patients</div>
        </div>
        <div class="col-md-3 cc-stat">
          <div class="cc-stat-number">98%</div>
          <div class="cc-stat-label">Satisfaction Score</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Medical Services Section -->
  <section id="services" class="cc-section">
    <div class="container">
      <div class="text-center mb-5">
        <span class="cc-badge cc-badge-emerald mb-3"><i class="bi bi-heart-pulse"></i> Comprehensive Care</span>
        <h2 class="cc-section-title">Our Medical Services</h2>
        <p class="cc-section-subtitle">We offer specialized clinical care across major departments, bringing experienced professionals together under one ecosystem.</p>
      </div>

      <div class="row g-4">
        <!-- Cardiology -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0s;">
          <div class="cc-service-card">
            <div class="cc-service-icon cc-service-icon-danger"><i class="bi bi-heart-pulse-fill"></i></div>
            <h4 class="fw-bold mb-3" style="color:var(--cc-slate-900);">Cardiology</h4>
            <p class="text-muted small mb-0" style="line-height:1.7;">Comprehensive heart diagnoses, stress tests, ECG checks, and care planning managed by top-tier cardiologists.</p>
          </div>
        </div>

        <!-- Pediatrics -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0.1s;">
          <div class="cc-service-card">
            <div class="cc-service-icon cc-service-icon-emerald"><i class="bi bi-emoji-smile-fill"></i></div>
            <h4 class="fw-bold mb-3" style="color:var(--cc-slate-900);">Pediatrics</h4>
            <p class="text-muted small mb-0" style="line-height:1.7;">Delightful, warm, and highly skilled child healthcare, standard immunizations, and child development checkups.</p>
          </div>
        </div>

        <!-- Dental Care -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0.2s;">
          <div class="cc-service-card">
            <div class="cc-service-icon cc-service-icon-info"><i class="bi bi-shield-check"></i></div>
            <h4 class="fw-bold mb-3" style="color:var(--cc-slate-900);">Dental Care</h4>
            <p class="text-muted small mb-0" style="line-height:1.7;">Modern orthodontics, dental surgeries, preventive cleanings, and emergency oral care for all ages.</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-5">
        <a href="/services" class="btn btn-cc-outline px-4">
          <i class="bi bi-grid-fill me-2"></i> View All Specializations
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Clinics Section -->
  <section id="clinics" class="cc-section cc-section-alt">
    <div class="container">
      <div class="text-center mb-5">
        <span class="cc-badge cc-badge-indigo mb-3"><i class="bi bi-hospital"></i> Trusted Partners</span>
        <h2 class="cc-section-title">Our Multi-specialty Clinics</h2>
        <p class="cc-section-subtitle">Browse through top clinical centers partnered with CareConnect. Book slot allocations immediately.</p>
      </div>

      <div class="row g-4">
        <!-- Clinic 1 -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0s;">
          <div class="cc-card">
            <div style="overflow:hidden;">
              <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&w=500&q=80" class="cc-card-img" alt="City Health Plaza">
            </div>
            <div class="cc-card-body">
              <h5 class="fw-bold mb-2" style="color:var(--cc-slate-900);">City Health Plaza</h5>
              <p class="text-muted small mb-3"><i class="bi bi-geo-alt-fill text-success me-1"></i> 4th Avenue, Sector 5, Salt Lake City</p>
              <p class="small text-muted mb-4">A high-end center providing premium Cardiology, Orthopedics, and Pediatric checkups with 24/7 care support.</p>
              <div class="d-flex justify-content-between align-items-center pt-3" style="border-top:1px solid var(--cc-slate-200);">
                <div class="small fw-bold" style="color:var(--cc-slate-900);"><i class="bi bi-star-fill text-warning me-1"></i> 4.8 Rating</div>
                <a href="/patient/login-view" class="btn btn-cc-primary btn-sm px-3">Book Clinic</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Clinic 2 -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0.1s;">
          <div class="cc-card">
            <div style="overflow:hidden;">
              <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&w=500&q=80" class="cc-card-img" alt="CarePrime Medical Hub">
            </div>
            <div class="cc-card-body">
              <h5 class="fw-bold mb-2" style="color:var(--cc-slate-900);">CarePrime Medical Hub</h5>
              <p class="text-muted small mb-3"><i class="bi bi-geo-alt-fill text-success me-1"></i> 18 Park Lane, Near Mall Row, City Centre</p>
              <p class="small text-muted mb-4">Equipped with state-of-the-art diagnostic facilities and specialized labs, focusing on Dental and General Medicine.</p>
              <div class="d-flex justify-content-between align-items-center pt-3" style="border-top:1px solid var(--cc-slate-200);">
                <div class="small fw-bold" style="color:var(--cc-slate-900);"><i class="bi bi-star-fill text-warning me-1"></i> 4.9 Rating</div>
                <a href="/patient/login-view" class="btn btn-cc-primary btn-sm px-3">Book Clinic</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Clinic 3 -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0.2s;">
          <div class="cc-card">
            <div style="overflow:hidden;">
              <img src="https://images.unsplash.com/photo-1584515979956-d9f6e5d09982?auto=format&fit=crop&w=500&q=80" class="cc-card-img" alt="Metro Life Clinical Care">
            </div>
            <div class="cc-card-body">
              <h5 class="fw-bold mb-2" style="color:var(--cc-slate-900);">Metro Life Clinical Care</h5>
              <p class="text-muted small mb-3"><i class="bi bi-geo-alt-fill text-success me-1"></i> 102 Regency Road, Greenfield Avenue</p>
              <p class="small text-muted mb-4">Focused on Neurology, child healthcare services, and standard diagnostics, providing excellent patient hospitality.</p>
              <div class="d-flex justify-content-between align-items-center pt-3" style="border-top:1px solid var(--cc-slate-200);">
                <div class="small fw-bold" style="color:var(--cc-slate-900);"><i class="bi bi-star-fill text-warning me-1"></i> 4.7 Rating</div>
                <a href="/patient/login-view" class="btn btn-cc-primary btn-sm px-3">Book Clinic</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-5">
        <a href="/clinics" class="btn btn-cc-outline px-4">
          <i class="bi bi-hospital-fill me-2"></i> View All Clinics
        </a>
      </div>
    </div>
  </section>

  <!-- Certified Specialists Section -->
  <section id="doctors" class="cc-section">
    <div class="container">
      <div class="text-center mb-5">
        <span class="cc-badge cc-badge-emerald mb-3"><i class="bi bi-person-badge"></i> Certified Care</span>
        <h2 class="cc-section-title">Our Certified Specialists</h2>
        <p class="cc-section-subtitle">Meet our elite medical practitioners. Click to allocate appointments and consult digitally.</p>
      </div>

      <div class="row g-4 justify-content-center">
        <!-- Doctor 1 -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0s;">
          <div class="cc-doctor-card text-center h-100">
            <div style="overflow:hidden;">
              <img src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&w=500&q=80" class="cc-doctor-img" alt="Dr. David Harrison">
            </div>
            <div class="p-4">
              <h5 class="fw-bold mb-1" style="color:var(--cc-slate-900);">Dr. David Harrison</h5>
              <span class="cc-badge cc-badge-indigo mb-3" style="font-size:10px;">Senior Cardiologist</span>
              <p class="small text-muted mb-4">Over 15+ years of cardiology experience, specialized in structural heart diagnoses.</p>
              <div class="d-flex justify-content-center gap-1 mb-3 text-warning">
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
              </div>
              <a href="/patient/login-view" class="btn btn-cc-primary btn-sm w-100">Book Appointment</a>
            </div>
          </div>
        </div>

        <!-- Doctor 2 -->
        <div class="col-lg-4 col-md-6 cc-fade-up" style="transition-delay:0.1s;">
          <div class="cc-doctor-card text-center h-100">
            <div style="overflow:hidden;">
              <img src="https://images.unsplash.com/photo-1594824813573-246434de83fb?auto=format&fit=crop&w=500&q=80" class="cc-doctor-img" alt="Dr. Sarah Jenkins">
            </div>
            <div class="p-4">
              <h5 class="fw-bold mb-1" style="color:var(--cc-slate-900);">Dr. Sarah Jenkins</h5>
              <span class="cc-badge cc-badge-indigo mb-3" style="font-size:10px;">Lead Pediatrician</span>
              <p class="small text-muted mb-4">Passionate child development healthcare practitioner, loved by families and toddlers.</p>
              <div class="d-flex justify-content-center gap-1 mb-3 text-warning">
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
              </div>
              <a href="/patient/login-view" class="btn btn-cc-primary btn-sm w-100">Book Appointment</a>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-5">
        <a href="/doctors" class="btn btn-cc-outline px-4">
          <i class="bi bi-people-fill me-2"></i> Meet All Specialists
        </a>
      </div>
    </div>
  </section>

  <!-- About Gateway Section -->
  <section id="about" class="cc-section cc-section-alt">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-6 cc-fade-left">
          <span class="cc-badge cc-badge-emerald mb-3"><i class="bi bi-shield-check"></i> Unified Network</span>
          <h2 class="cc-section-title mb-4">Unifying Medical Service Centers Under One Digital Platform</h2>
          <p class="text-muted mb-4" style="line-height:1.8;">
            CareConnect bridges the gap between medical practitioners and patients. We provide highly robust, HIPAA-compliant patient check-ins, transparent rating feedbacks, automated prescription management, and verified clinician schedules.
          </p>
          <div class="row g-4 mb-4">
            <div class="col-sm-6">
              <div class="d-flex align-items-center gap-3">
                <div class="cc-service-icon cc-service-icon-success mb-0" style="width:48px; height:48px; font-size:20px; border-radius:10px;">
                  <i class="bi bi-shield-lock-fill"></i>
                </div>
                <div>
                  <h6 class="fw-bold mb-0" style="color:var(--cc-slate-900);">100% Secure Data</h6>
                  <small class="text-muted">HIPAA-compliant records</small>
                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="d-flex align-items-center gap-3">
                <div class="cc-service-icon cc-service-icon-indigo mb-0" style="width:48px; height:48px; font-size:20px; border-radius:10px;">
                  <i class="bi bi-patch-check-fill"></i>
                </div>
                <div>
                  <h6 class="fw-bold mb-0" style="color:var(--cc-slate-900);">Certified Specialists</h6>
                  <small class="text-muted">Verified clinic practitioners</small>
                </div>
              </div>
            </div>
          </div>
          <a href="/about" class="btn btn-cc-primary px-4">
            <i class="bi bi-book-fill me-2"></i> Read Our Full Story
          </a>
        </div>
        <div class="col-lg-6 cc-fade-right">
          <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=800&q=80" alt="doctors team" class="img-fluid" style="border-radius:var(--radius-xl); box-shadow:var(--shadow-xl);">
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <%- include('partials/chat-widget') %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.cc-fade-up, .cc-fade-left, .cc-fade-right').forEach(el => observer.observe(el));
  </script>
</body>
</html>
