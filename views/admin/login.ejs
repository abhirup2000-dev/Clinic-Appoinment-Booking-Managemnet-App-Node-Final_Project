<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — CareConnect</title>
  <meta name="description" content="Secure admin login for CareConnect clinic management system.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', sans-serif;
      padding: 40px 20px;
    }

    .login-wrapper {
      width: 100%;
      max-width: 480px;
    }

    .login-card {
      border: none;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(14, 165, 233, 0.15);
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      padding: 50px 40px;
    }

    .brand-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .brand-icon {
      font-size: 36px;
      color: #0284c7;
      margin-bottom: 10px;
      display: inline-block;
      background: rgba(2, 132, 199, 0.1);
      width: 70px;
      height: 70px;
      line-height: 70px;
      border-radius: 50%;
    }

    .form-control {
      height: 50px;
      border-radius: 12px;
      border: 1.5px solid #e2e8f0;
      padding-left: 16px;
      font-size: 15px;
      background: #f8fafc;
      transition: all 0.3s ease;
    }

    .form-control:focus {
      border-color: #0284c7;
      background: #fff;
      box-shadow: 0 0 0 4px rgba(2, 132, 199, 0.1);
    }

    .btn-login {
      height: 52px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 16px;
      background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
      border: none;
      color: white;
      transition: all 0.3s ease;
      margin-top: 15px;
      width: 100%;
    }

    .btn-login:hover {
      background: linear-gradient(135deg, #0369a1 0%, #075985 100%);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(2, 132, 199, 0.3);
      color: white;
    }

    .form-label {
      font-weight: 600;
      color: #475569;
      margin-bottom: 6px;
      font-size: 14px;
    }
    
    .register-link {
      color: #0284c7;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }
    
    .register-link:hover {
      color: #0369a1;
      text-decoration: underline;
    }

    .form-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .remember-check { display: flex; align-items: center; gap: 8px; cursor: pointer; }
    .remember-check input { accent-color: #0284c7; width: 15px; height: 15px; cursor: pointer; }
    .remember-check span { font-size: 14px; color: #475569; font-weight: 500; }
    .forgot-link { font-size: 14px; color: #0284c7; text-decoration: none; font-weight: 600; }
    .forgot-link:hover { color: #0369a1; text-decoration: underline; }
    .input-wrap { position: relative; }
    .pass-toggle { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: #475569; cursor: pointer; font-size: 16px; }
    .pass-toggle:hover { color: #0284c7; }

    @media (max-width: 576px) {
      .login-card {
        padding: 40px 30px;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/flash') %>

  <div class="login-wrapper">
    <div class="card login-card">
      <div class="brand-header">
        <div class="brand-icon">
          <i class="bi bi-shield-lock"></i>
        </div>
        <h3 class="fw-bold text-dark mb-1">Admin Portal</h3>
        <p class="text-muted small mb-0">Sign in to access your admin dashboard</p>
      </div>

      <form action="/admin/login" method="POST" id="loginForm">
        <div class="mb-4">
          <label class="form-label" for="adminEmail">Email Address</label>
          <input type="email" id="adminEmail" name="email" class="form-control" placeholder="admin@careconnect.com" required autocomplete="email">
        </div>

        <div class="mb-4">
          <label class="form-label" for="adminPassword">Password</label>
          <div class="input-wrap">
            <input type="password" id="adminPassword" name="password" class="form-control" placeholder="Enter your password" required autocomplete="current-password">
            <i class="bi bi-eye pass-toggle" id="togglePass"></i>
          </div>
        </div>

        <div class="form-row">
          <label class="remember-check">
            <input type="checkbox" id="rememberMe" name="remember">
            <span>Remember me</span>
          </label>
          <a href="/admin/forgot-password" class="forgot-link">Forgot password?</a>
        </div>

        <button type="submit" class="btn w-100 btn-login" id="loginBtn">
          Sign In to Dashboard <i class="bi bi-box-arrow-in-right ms-2"></i>
        </button>

        <div class="text-center mt-4">
          <p class="mb-0 text-muted small">
            Don't have an admin account?
            <a href="/admin/register-view" class="register-link">Register here</a>
          </p>
        </div>
      </form>
    </div>
    
    <div class="text-center mt-4 text-muted small fw-medium">
      © 2026 CareConnect Systems
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Password toggle
    document.getElementById('togglePass').addEventListener('click', function() {
      const p = document.getElementById('adminPassword');
      p.type = p.type === 'password' ? 'text' : 'password';
      this.className = 'bi pass-toggle ' + (p.type === 'text' ? 'bi-eye-slash' : 'bi-eye');
    });

    // Button loading state
    document.getElementById('loginForm').addEventListener('submit', function() {
      const btn = document.getElementById('loginBtn');
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Signing in…';
      btn.disabled = true;
    });
  </script>
</body>
</html>