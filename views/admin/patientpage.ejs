<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Patients — CareConnect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    :root { --sidebar-w: 270px; --topbar-h: 70px; }
    body { background: #0f1117; font-family: 'Inter', sans-serif; color: #e2e8f0; min-height: 100vh; }

    .cc-sidebar {
      width: var(--sidebar-w); position: fixed; top: 0; left: 0; height: 100vh;
      background: linear-gradient(180deg, #13151f 0%, #0d0f18 100%);
      border-right: 1px solid rgba(255,255,255,.06);
      display: flex; flex-direction: column; z-index: 1000; overflow-y: auto;
    }
    .sidebar-brand {
      padding: 24px 22px 18px; border-bottom: 1px solid rgba(255,255,255,.06);
      display: flex; align-items: center; gap: 12px;
    }
    .brand-icon { width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, #10b981, #6366f1); display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .brand-name { font-size: 17px; font-weight: 800; color: #fff; letter-spacing: -.3px; }
    .brand-sub  { font-size: 10px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; }
    .sidebar-nav { padding: 18px 14px; flex: 1; }
    .nav-section-label { font-size: 9.5px; font-weight: 700; letter-spacing: 1.5px; color: #475569; text-transform: uppercase; padding: 0 8px; margin: 18px 0 8px; }
    .nav-item { display: flex; align-items: center; gap: 11px; padding: 10px 14px; border-radius: 10px; color: #94a3b8; text-decoration: none; font-size: 14px; font-weight: 500; transition: all .2s; margin-bottom: 2px; }
    .nav-item:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
    .nav-item.active { background: rgba(16,185,129,.12); color: #10b981; }
    .nav-item i { font-size: 17px; width: 20px; text-align: center; }
    .nav-badge { margin-left: auto; background: #10b981; color: #fff; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px; }
    .sidebar-footer { padding: 16px 14px; border-top: 1px solid rgba(255,255,255,.06); }
    .logout-btn { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 10px; color: #f87171; text-decoration: none; font-size: 14px; font-weight: 500; transition: background .2s; }
    .logout-btn:hover { background: rgba(248,113,113,.1); color: #f87171; }

    .cc-main { margin-left: var(--sidebar-w); min-height: 100vh; background: #0f1117; }
    .cc-topbar {
      height: var(--topbar-h); background: rgba(15,17,23,.95); backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,.06);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px; position: sticky; top: 0; z-index: 100;
    }
    .topbar-title { font-size: 19px; font-weight: 700; color: #f1f5f9; }
    .topbar-sub   { font-size: 12px; color: #64748b; margin-top: 1px; }
    .topbar-actions { display: flex; align-items: center; gap: 12px; }
    .notif-btn {
      width: 40px; height: 40px; border-radius: 10px; background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08); color: #94a3b8;
      display: flex; align-items: center; justify-content: center;
      font-size: 17px; cursor: pointer; transition: all .2s; position: relative;
    }
    .notif-btn:hover { background: rgba(255,255,255,.1); color: #e2e8f0; }
    .notif-dot { position: absolute; top: 7px; right: 7px; width: 8px; height: 8px; border-radius: 50%; background: #10b981; border: 2px solid #0f1117; display: none; }

    .cc-content { padding: 28px; }

    .stats-strip { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 24px; }
    .stat-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 14px; padding: 18px 20px; display: flex; align-items: center; gap: 14px; transition: all .2s; }
    .stat-card:hover { background: rgba(255,255,255,.05); border-color: rgba(16,185,129,.2); }
    .stat-icon { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .stat-icon.emerald { background: rgba(16,185,129,.15); color: #10b981; }
    .stat-icon.indigo  { background: rgba(99,102,241,.15);  color: #6366f1; }
    .stat-icon.amber   { background: rgba(245,158,11,.15);  color: #f59e0b; }
    .stat-icon.rose    { background: rgba(244,63,94,.15);   color: #f43f5e; }
    .stat-val  { font-size: 24px; font-weight: 800; color: #f1f5f9; line-height: 1; }
    .stat-label{ font-size: 12px; color: #64748b; margin-top: 3px; }

    .table-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 16px; overflow: hidden; }
    .table-card-header { padding: 18px 22px; border-bottom: 1px solid rgba(255,255,255,.06); display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; }
    .search-box { display: flex; align-items: center; gap: 9px; padding: 9px 14px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; width: 240px; }
    .search-box i { color: #64748b; font-size: 14px; }
    .search-box input { background: transparent; border: none; outline: none; color: #e2e8f0; font-size: 13px; width: 100%; }
    .search-box input::placeholder { color: #475569; }

    .cc-table { width: 100%; border-collapse: collapse; }
    .cc-table thead tr { background: rgba(255,255,255,.03); border-bottom: 1px solid rgba(255,255,255,.06); }
    .cc-table th { padding: 13px 18px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: #64748b; white-space: nowrap; }
    .cc-table tbody tr { border-bottom: 1px solid rgba(255,255,255,.04); transition: background .15s; }
    .cc-table tbody tr:hover { background: rgba(255,255,255,.03); }
    .cc-table tbody tr:last-child { border-bottom: none; }
    .cc-table td { padding: 14px 18px; vertical-align: middle; }
    .pat-avatar { width: 42px; height: 42px; border-radius: 12px; object-fit: cover; border: 2px solid rgba(99,102,241,.35); }
    .pat-name  { font-size: 14px; font-weight: 600; color: #f1f5f9; }
    .pat-id    { font-size: 11px; color: #475569; font-family: 'Courier New', monospace; margin-top: 1px; }
    .contact-item { font-size: 12px; color: #94a3b8; display: flex; align-items: center; gap: 5px; margin-bottom: 2px; }
    .cc-badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; white-space: nowrap; }
    .badge-active   { background: rgba(16,185,129,.15); color: #10b981; border: 1px solid rgba(16,185,129,.25); }
    .badge-inactive { background: rgba(244,63,94,.12);  color: #f43f5e; border: 1px solid rgba(244,63,94,.2); }
    .action-btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 13px; border-radius: 8px; border: 1px solid rgba(255,255,255,.08); background: rgba(255,255,255,.04); color: #94a3b8; font-size: 12px; font-weight: 600; cursor: pointer; transition: all .2s; text-decoration: none; }
    .action-btn:hover { background: rgba(99,102,241,.15); color: #818cf8; border-color: rgba(99,102,241,.3); }
    .action-btn.warn:hover  { background: rgba(245,158,11,.12); color: #f59e0b; border-color: rgba(245,158,11,.3); }
    .action-btn.danger:hover{ background: rgba(244,63,94,.12);  color: #f43f5e; border-color: rgba(244,63,94,.25); }
    .empty-state { padding: 60px; text-align: center; color: #475569; }
    .empty-state i { font-size: 48px; margin-bottom: 14px; display: block; color: #334155; }

    #notifToast {
      position: fixed; top: 80px; right: 24px; z-index: 9999;
      background: #171a25; border: 1px solid rgba(16,185,129,.3);
      border-radius: 14px; padding: 14px 18px; max-width: 320px;
      display: flex; align-items: flex-start; gap: 12px;
      box-shadow: 0 8px 32px rgba(0,0,0,.5); transform: translateX(120%);
      transition: transform .4s cubic-bezier(.34,1.56,.64,1);
    }
    #notifToast.show { transform: translateX(0); }
    .toast-icon { font-size: 22px; color: #10b981; flex-shrink: 0; margin-top: 2px; }
    .toast-title { font-size: 13px; font-weight: 700; color: #f1f5f9; }
    .toast-msg   { font-size: 12px; color: #94a3b8; margin-top: 2px; }

    @media (max-width: 991px) {
      .cc-sidebar { transform: translateX(-100%); }
      .cc-main { margin-left: 0; }
      .stats-strip { grid-template-columns: repeat(2,1fr); }
    }
  </style>
</head>
<body>
  <%- include('../partials/flash') %>

  <!-- Sidebar -->
  <aside class="cc-sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">🏥</div>
      <div>
        <div class="brand-name">CareConnect</div>
        <div class="brand-sub">Admin Panel</div>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Main</div>
      <a href="/admin/dashboard" class="nav-item"><i class="bi bi-speedometer2"></i> Overview</a>
      <a href="/admin/profile"   class="nav-item"><i class="bi bi-person-circle"></i> My Profile</a>
      <div class="nav-section-label">Management</div>
      <a href="/admin/appointments" class="nav-item"><i class="bi bi-calendar-check"></i> Appointments</a>
      <a href="/admin/doctors"      class="nav-item"><i class="bi bi-person-badge"></i> Doctors</a>
      <a href="/admin/patients"     class="nav-item active"><i class="bi bi-people"></i> Patients <span class="nav-badge"><%= patients.length %></span></a>
      <a href="/admin/clinics"      class="nav-item"><i class="bi bi-hospital"></i> Clinics</a>
      <div class="nav-section-label">Reports</div>
      <a href="/admin/feedback" class="nav-item"><i class="bi bi-star-half"></i> Feedback</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="logout-btn"><i class="bi bi-box-arrow-right"></i> Sign Out</a>
    </div>
  </aside>

  <!-- Main -->
  <div class="cc-main">
    <div class="cc-topbar">
      <div>
        <div class="topbar-title">Manage Patients</div>
        <div class="topbar-sub">View registered patients, block/unblock accounts</div>
      </div>
      <div class="topbar-actions">
        <div class="notif-btn" id="notifBell" title="Notifications">
          <i class="bi bi-bell"></i>
          <span class="notif-dot" id="notifDot"></span>
        </div>
      </div>
    </div>

    <div class="cc-content">
      <!-- Stats -->
      <div class="stats-strip">
        <div class="stat-card">
          <div class="stat-icon emerald"><i class="bi bi-people"></i></div>
          <div><div class="stat-val"><%= patients.length %></div><div class="stat-label">Total Patients</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon indigo"><i class="bi bi-person-check"></i></div>
          <div><div class="stat-val"><%= patients.filter(p => p.status === 'active').length %></div><div class="stat-label">Active</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon rose"><i class="bi bi-shield-lock"></i></div>
          <div><div class="stat-val"><%= patients.filter(p => p.status !== 'active').length %></div><div class="stat-label">Blocked</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon amber"><i class="bi bi-calendar-plus"></i></div>
          <div>
            <div class="stat-val"><%= patients.filter(p => { const d = new Date(p.createdAt); const now = new Date(); return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear(); }).length %></div>
            <div class="stat-label">New This Month</div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="table-card">
        <div class="table-card-header">
          <div style="font-size:15px;font-weight:700;color:#f1f5f9;">All Registered Patients</div>
          <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="patientSearch" placeholder="Search by name or email…">
          </div>
        </div>
        <div class="table-responsive">
          <table class="cc-table" id="patientTable">
            <thead>
              <tr>
                <th>Patient</th>
                <th>Contact Details</th>
                <th>Gender / Age</th>
                <th>Status</th>
                <th>Joined Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (patients.length === 0) { %>
                <tr>
                  <td colspan="6">
                    <div class="empty-state">
                      <i class="bi bi-people"></i>
                      <p>No patients registered in the system yet.</p>
                    </div>
                  </td>
                </tr>
              <% } else { %>
                <% patients.forEach(patient => { %>
                  <tr class="pat-row" data-name="<%= patient.name.toLowerCase() %>" data-email="<%= patient.email.toLowerCase() %>">
                    <td>
                      <div style="display:flex;align-items:center;gap:12px;">
                        <img src="<%= patient.profilePicture || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(patient.name) + '&background=6366f1&color=fff&size=80' %>"
                             alt="<%= patient.name %>" class="pat-avatar">
                        <div>
                          <div class="pat-name"><%= patient.name %></div>
                          <div class="pat-id">#<%= patient._id.toString().slice(-8).toUpperCase() %></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <div class="contact-item"><i class="bi bi-envelope"></i> <%= patient.email %></div>
                      <div class="contact-item"><i class="bi bi-telephone"></i> <%= patient.phone || 'N/A' %></div>
                    </td>
                    <td><span style="font-size:13px;color:#94a3b8;"><%= patient.gender || 'Not Specified' %> / <%= patient.age || '—' %> yrs</span></td>
                    <td>
                      <span class="cc-badge <%= patient.status === 'active' ? 'badge-active' : 'badge-inactive' %>">
                        <i class="bi bi-circle-fill" style="font-size:6px;"></i>
                        <%= patient.status === 'active' ? 'Active' : 'Blocked' %>
                      </span>
                    </td>
                    <td><span style="font-size:13px;color:#64748b;"><%= new Date(patient.createdAt).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) %></span></td>
                    <td>
                      <div style="display:flex;gap:7px;flex-wrap:wrap;">
                        <form action="/admin/patients/toggle-status/<%= patient._id %>" method="POST" style="display:inline;">
                          <button type="submit" class="action-btn <%= patient.status === 'active' ? 'warn' : '' %>" title="<%= patient.status === 'active' ? 'Block' : 'Unblock' %>">
                            <i class="bi bi-shield-<%= patient.status === 'active' ? 'lock' : 'check' %>"></i>
                            <%= patient.status === 'active' ? 'Block' : 'Unblock' %>
                          </button>
                        </form>
                        <form action="/admin/patients/delete/<%= patient._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Permanently delete this patient?');">
                          <button type="submit" class="action-btn danger" title="Delete">
                            <i class="bi bi-trash"></i> Delete
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="notifToast">
    <div class="toast-icon"><i class="bi bi-bell-fill"></i></div>
    <div>
      <div class="toast-title" id="toastTitle">Notification</div>
      <div class="toast-msg"  id="toastMsg"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    document.getElementById('patientSearch').addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.pat-row').forEach(row => {
        const name  = row.dataset.name  || '';
        const email = row.dataset.email || '';
        row.style.display = (name.includes(q) || email.includes(q)) ? '' : 'none';
      });
    });

    const socket = io();
    <% if (typeof admin !== 'undefined' && admin) { %>
      socket.emit('join', 'user_<%= admin._id %>');
    <% } %>

    function showToast(title, msg) {
      document.getElementById('toastTitle').textContent = title;
      document.getElementById('toastMsg').textContent   = msg;
      document.getElementById('notifDot').style.display = 'block';
      const t = document.getElementById('notifToast');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 5000);
    }
    socket.on('notification', data => showToast(data.title || 'Notification', data.message || ''));
  </script>
</body>
</html>
