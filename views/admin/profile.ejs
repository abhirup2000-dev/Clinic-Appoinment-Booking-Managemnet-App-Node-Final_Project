<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Profile — CareConnect</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    :root { --sidebar-w: 270px; --topbar-h: 70px; }
    body { background: #0f1117; font-family: 'Inter', sans-serif; color: #e2e8f0; min-height: 100vh; }

    .cc-sidebar { width: var(--sidebar-w); position: fixed; top: 0; left: 0; height: 100vh; background: linear-gradient(180deg, #13151f 0%, #0d0f18 100%); border-right: 1px solid rgba(255,255,255,.06); display: flex; flex-direction: column; z-index: 1000; overflow-y: auto; }
    .sidebar-brand { padding: 24px 22px 18px; border-bottom: 1px solid rgba(255,255,255,.06); display: flex; align-items: center; gap: 12px; }
    .brand-icon { width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, #10b981, #6366f1); display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .brand-name { font-size: 17px; font-weight: 800; color: #fff; letter-spacing: -.3px; }
    .brand-sub  { font-size: 10px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; }
    .sidebar-nav { padding: 18px 14px; flex: 1; }
    .nav-section-label { font-size: 9.5px; font-weight: 700; letter-spacing: 1.5px; color: #475569; text-transform: uppercase; padding: 0 8px; margin: 18px 0 8px; }
    .nav-item { display: flex; align-items: center; gap: 11px; padding: 10px 14px; border-radius: 10px; color: #94a3b8; text-decoration: none; font-size: 14px; font-weight: 500; transition: all .2s; margin-bottom: 2px; }
    .nav-item:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
    .nav-item.active { background: rgba(16,185,129,.12); color: #10b981; }
    .nav-item i { font-size: 17px; width: 20px; text-align: center; }
    .sidebar-footer { padding: 16px 14px; border-top: 1px solid rgba(255,255,255,.06); }
    .logout-btn { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 10px; color: #f87171; text-decoration: none; font-size: 14px; font-weight: 500; transition: background .2s; }
    .logout-btn:hover { background: rgba(248,113,113,.1); color: #f87171; }

    .cc-main { margin-left: var(--sidebar-w); min-height: 100vh; }
    .cc-topbar { height: var(--topbar-h); background: rgba(15,17,23,.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,.06); display: flex; align-items: center; padding: 0 28px; position: sticky; top: 0; z-index: 100; }
    .topbar-title { font-size: 19px; font-weight: 700; color: #f1f5f9; }
    .topbar-sub   { font-size: 12px; color: #64748b; margin-top: 1px; }

    .cc-content { padding: 28px; max-width: 860px; }

    /* Hero card */
    .profile-hero {
      background: linear-gradient(135deg, rgba(16,185,129,.1), rgba(99,102,241,.08));
      border: 1px solid rgba(16,185,129,.2); border-radius: 20px;
      padding: 32px; margin-bottom: 24px; position: relative; overflow: hidden;
    }
    .profile-hero::before {
      content: ''; position: absolute; top: -40px; right: -40px;
      width: 180px; height: 180px; border-radius: 50%;
      background: rgba(16,185,129,.07); pointer-events: none;
    }
    .profile-avatar {
      width: 90px; height: 90px; border-radius: 22px; object-fit: cover;
      border: 3px solid rgba(16,185,129,.4); flex-shrink: 0;
    }
    .profile-name  { font-size: 24px; font-weight: 800; color: #f1f5f9; line-height: 1.2; }
    .profile-email { font-size: 14px; color: #64748b; margin-top: 4px; }
    .profile-badge {
      display: inline-flex; align-items: center; gap: 6px; margin-top: 10px;
      background: rgba(16,185,129,.15); border: 1px solid rgba(16,185,129,.3);
      color: #10b981; padding: 5px 13px; border-radius: 20px; font-size: 12px; font-weight: 700;
    }

    /* Form cards */
    .form-card {
      background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
      border-radius: 18px; padding: 28px; margin-bottom: 20px;
    }
    .form-card-title {
      font-size: 16px; font-weight: 700; color: #f1f5f9; margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
    }
    .form-card-title i { font-size: 18px; color: #10b981; }
    .form-label { font-size: 12px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 7px; }
    .form-control, .form-select {
      background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
      border-radius: 12px; color: #e2e8f0; padding: 12px 16px; font-size: 14px;
      transition: all .2s; font-family: 'Inter', sans-serif;
    }
    .form-control:focus, .form-select:focus {
      background: rgba(255,255,255,.07); border-color: #10b981;
      box-shadow: 0 0 0 3px rgba(16,185,129,.15); color: #f1f5f9; outline: none;
    }
    .form-control::placeholder { color: #475569; }
    .btn-update {
      padding: 13px 28px; border: none; border-radius: 12px;
      background: linear-gradient(135deg, #10b981, #059669);
      color: #fff; font-size: 15px; font-weight: 700; cursor: pointer; transition: all .2s;
    }
    .btn-update:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(16,185,129,.35); }
    .btn-danger-outline {
      padding: 13px 28px; border: 1px solid rgba(244,63,94,.3); border-radius: 12px;
      background: rgba(244,63,94,.08); color: #f43f5e;
      font-size: 15px; font-weight: 700; cursor: pointer; transition: all .2s;
    }
    .btn-danger-outline:hover { background: rgba(244,63,94,.15); border-color: rgba(244,63,94,.5); transform: translateY(-1px); }

    .divider { border: none; border-top: 1px solid rgba(255,255,255,.06); margin: 4px 0 20px; }

    @media (max-width: 991px) {
      .cc-sidebar { transform: translateX(-100%); }
      .cc-main { margin-left: 0; }
    }
  </style>
</head>
<body>
  <%- include('../partials/flash') %>

  <aside class="cc-sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">🏥</div>
      <div>
        <div class="brand-name">CareConnect</div>
        <div class="brand-sub">Admin Panel</div>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Main</div>
      <a href="/admin/dashboard" class="nav-item"><i class="bi bi-speedometer2"></i> Overview</a>
      <a href="/admin/profile"   class="nav-item active"><i class="bi bi-person-circle"></i> My Profile</a>
      <div class="nav-section-label">Management</div>
      <a href="/admin/appointments" class="nav-item"><i class="bi bi-calendar-check"></i> Appointments</a>
      <a href="/admin/doctors"      class="nav-item"><i class="bi bi-person-badge"></i> Doctors</a>
      <a href="/admin/patients"     class="nav-item"><i class="bi bi-people"></i> Patients</a>
      <a href="/admin/clinics"      class="nav-item"><i class="bi bi-hospital"></i> Clinics</a>
      <div class="nav-section-label">Reports</div>
      <a href="/admin/feedback" class="nav-item"><i class="bi bi-star-half"></i> Feedback</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="logout-btn"><i class="bi bi-box-arrow-right"></i> Sign Out</a>
    </div>
  </aside>

  <div class="cc-main">
    <div class="cc-topbar">
      <div>
        <div class="topbar-title">Admin Profile</div>
        <div class="topbar-sub">Manage your account details & credentials</div>
      </div>
    </div>

    <div class="cc-content">

      <!-- Profile Hero -->
      <div class="profile-hero">
        <div style="display:flex;align-items:center;gap:22px;flex-wrap:wrap;">
          <img src="<%= admin.profilePicture || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(admin.name) + '&background=10b981&color=fff&size=120' %>"
               alt="<%= admin.name %>" class="profile-avatar">
          <div>
            <div class="profile-name"><%= admin.name %></div>
            <div class="profile-email"><i class="bi bi-envelope me-2"></i><%= admin.email %></div>
            <% if (admin.phone) { %><div class="profile-email" style="margin-top:2px;"><i class="bi bi-telephone me-2"></i><%= admin.phone %></div><% } %>
            <div class="profile-badge"><i class="bi bi-shield-check"></i> Super Admin</div>
          </div>
        </div>
      </div>

      <!-- Update Profile Form -->
      <div class="form-card">
        <div class="form-card-title"><i class="bi bi-person-gear"></i> Update Profile Details</div>
        <hr class="divider">
        <form action="/admin/update-profile" method="POST" enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Full Name</label>
              <input type="text" name="name" class="form-control" value="<%= admin.name %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Phone Number</label>
              <input type="text" name="phone" class="form-control" value="<%= admin.phone %>" placeholder="+91 00000 00000">
            </div>
            <div class="col-12">
              <label class="form-label">Email Address</label>
              <input type="email" name="email" class="form-control" value="<%= admin.email %>" required>
            </div>
            <div class="col-12">
              <label class="form-label">Profile Picture</label>
              <input type="file" name="profilePicture" class="form-control" accept="image/*">
            </div>
            <div class="col-12 mt-2">
              <button type="submit" class="btn-update"><i class="bi bi-check2 me-2"></i>Update Profile</button>
            </div>
          </div>
        </form>
      </div>

      <!-- Change Password Form -->
      <div class="form-card">
        <div class="form-card-title"><i class="bi bi-lock"></i> Change Password</div>
        <hr class="divider">
        <form action="/admin/update-password" method="POST">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Current Password</label>
              <input type="password" name="currentPassword" class="form-control" placeholder="Enter your current password" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">New Password</label>
              <input type="password" name="newPassword" id="newPass" class="form-control" placeholder="At least 8 characters" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Confirm New Password</label>
              <input type="password" name="confirmPassword" id="confirmPass" class="form-control" placeholder="Repeat new password" required>
            </div>
            <div class="col-12 mt-2">
              <button type="submit" class="btn-danger-outline"><i class="bi bi-shield-lock me-2"></i>Change Password</button>
            </div>
          </div>
        </form>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>