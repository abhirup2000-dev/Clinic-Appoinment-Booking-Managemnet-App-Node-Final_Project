<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Appointments — CareConnect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    :root {
      --sidebar-w: 270px;
      --topbar-h: 70px;
    }

    body {
      background: #0f1117;
      font-family: 'Inter', sans-serif;
      color: #e2e8f0;
      min-height: 100vh;
    }

    .cc-sidebar {
      width: var(--sidebar-w);
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      background: linear-gradient(180deg, #13151f 0%, #0d0f18 100%);
      border-right: 1px solid rgba(255, 255, 255, .06);
      display: flex;
      flex-direction: column;
      z-index: 1000;
      overflow-y: auto;
    }

    .sidebar-brand {
      padding: 24px 22px 18px;
      border-bottom: 1px solid rgba(255, 255, 255, .06);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: linear-gradient(135deg, #10b981, #6366f1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }

    .brand-name {
      font-size: 17px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -.3px;
    }

    .brand-sub {
      font-size: 10px;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .sidebar-nav {
      padding: 18px 14px;
      flex: 1;
    }

    .nav-section-label {
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: 1.5px;
      color: #475569;
      text-transform: uppercase;
      padding: 0 8px;
      margin: 18px 0 8px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 10px 14px;
      border-radius: 10px;
      color: #94a3b8;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: all .2s;
      margin-bottom: 2px;
    }

    .nav-item:hover {
      background: rgba(255, 255, 255, .06);
      color: #e2e8f0;
    }

    .nav-item.active {
      background: rgba(16, 185, 129, .12);
      color: #10b981;
    }

    .nav-item i {
      font-size: 17px;
      width: 20px;
      text-align: center;
    }

    .nav-badge {
      margin-left: auto;
      background: #10b981;
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 20px;
    }

    .sidebar-footer {
      padding: 16px 14px;
      border-top: 1px solid rgba(255, 255, 255, .06);
    }

    .logout-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 10px;
      color: #f87171;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: background .2s;
    }

    .logout-btn:hover {
      background: rgba(248, 113, 113, .1);
      color: #f87171;
    }

    .cc-main {
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      background: #0f1117;
    }

    .cc-topbar {
      height: var(--topbar-h);
      background: rgba(15, 17, 23, .95);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255, 255, 255, .06);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 28px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .topbar-title {
      font-size: 19px;
      font-weight: 700;
      color: #f1f5f9;
    }

    .topbar-sub {
      font-size: 12px;
      color: #64748b;
      margin-top: 1px;
    }

    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .notif-btn {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .08);
      color: #94a3b8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 17px;
      cursor: pointer;
      transition: all .2s;
      position: relative;
    }

    .notif-btn:hover {
      background: rgba(255, 255, 255, .1);
      color: #e2e8f0;
    }

    .notif-dot {
      position: absolute;
      top: 7px;
      right: 7px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #10b981;
      border: 2px solid #0f1117;
      display: none;
    }

    .cc-content {
      padding: 28px;
    }

    /* Status filter tabs */
    .filter-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .filter-tab {
      padding: 7px 16px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s;
      border: 1px solid rgba(255, 255, 255, .08);
      background: rgba(255, 255, 255, .03);
      color: #64748b;
    }

    .filter-tab:hover {
      background: rgba(255, 255, 255, .07);
      color: #e2e8f0;
    }

    .filter-tab.active {
      background: rgba(16, 185, 129, .15);
      color: #10b981;
      border-color: rgba(16, 185, 129, .3);
    }

    /* Stats */
    .stats-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .stat-card {
      background: rgba(255, 255, 255, .03);
      border: 1px solid rgba(255, 255, 255, .07);
      border-radius: 14px;
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      transition: all .2s;
    }

    .stat-card:hover {
      background: rgba(255, 255, 255, .05);
    }

    .stat-icon {
      width: 46px;
      height: 46px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }

    .stat-icon.emerald {
      background: rgba(16, 185, 129, .15);
      color: #10b981;
    }

    .stat-icon.indigo {
      background: rgba(99, 102, 241, .15);
      color: #6366f1;
    }

    .stat-icon.amber {
      background: rgba(245, 158, 11, .15);
      color: #f59e0b;
    }

    .stat-icon.rose {
      background: rgba(244, 63, 94, .15);
      color: #f43f5e;
    }

    .stat-val {
      font-size: 24px;
      font-weight: 800;
      color: #f1f5f9;
      line-height: 1;
    }

    .stat-label {
      font-size: 12px;
      color: #64748b;
      margin-top: 3px;
    }

    /* Table */
    .table-card {
      background: rgba(255, 255, 255, .03);
      border: 1px solid rgba(255, 255, 255, .07);
      border-radius: 16px;
      overflow: hidden;
    }

    .table-card-header {
      padding: 18px 22px;
      border-bottom: 1px solid rgba(255, 255, 255, .06);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      flex-wrap: wrap;
    }

    .search-box {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 9px 14px;
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 10px;
      width: 240px;
    }

    .search-box i {
      color: #64748b;
      font-size: 14px;
    }

    .search-box input {
      background: transparent;
      border: none;
      outline: none;
      color: #e2e8f0;
      font-size: 13px;
      width: 100%;
    }

    .search-box input::placeholder {
      color: #475569;
    }

    .cc-table {
      width: 100%;
      border-collapse: collapse;
    }

    .cc-table thead tr {
      background: rgba(255, 255, 255, .03);
      border-bottom: 1px solid rgba(255, 255, 255, .06);
    }

    .cc-table th {
      padding: 13px 18px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: #64748b;
      white-space: nowrap;
    }

    .cc-table tbody tr {
      border-bottom: 1px solid rgba(255, 255, 255, .04);
      transition: background .15s;
    }

    .cc-table tbody tr:hover {
      background: rgba(255, 255, 255, .03);
    }

    .cc-table tbody tr:last-child {
      border-bottom: none;
    }

    .cc-table td {
      padding: 14px 18px;
      vertical-align: middle;
    }

    .person-name {
      font-size: 14px;
      font-weight: 600;
      color: #f1f5f9;
    }

    .person-sub {
      font-size: 12px;
      color: #64748b;
      margin-top: 2px;
    }

    .cc-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 11px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      white-space: nowrap;
      text-transform: capitalize;
    }

    .badge-pending {
      background: rgba(245, 158, 11, .12);
      color: #f59e0b;
      border: 1px solid rgba(245, 158, 11, .25);
    }

    .badge-confirmed {
      background: rgba(99, 102, 241, .12);
      color: #818cf8;
      border: 1px solid rgba(99, 102, 241, .25);
    }

    .badge-completed {
      background: rgba(16, 185, 129, .12);
      color: #10b981;
      border: 1px solid rgba(16, 185, 129, .25);
    }

    .badge-cancelled {
      background: rgba(244, 63, 94, .1);
      color: #f43f5e;
      border: 1px solid rgba(244, 63, 94, .2);
    }

    .badge-dept {
      background: rgba(100, 116, 139, .12);
      color: #94a3b8;
      border: 1px solid rgba(100, 116, 139, .2);
    }

    /* Status select */
    .status-select {
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 8px;
      color: #e2e8f0;
      padding: 6px 10px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      width: 120px;
    }

    .status-select:focus {
      outline: none;
      border-color: #10b981;
    }

    .status-select option {
      background: #171a25;
    }

    .empty-state {
      padding: 60px;
      text-align: center;
      color: #475569;
    }

    .empty-state i {
      font-size: 48px;
      margin-bottom: 14px;
      display: block;
      color: #334155;
    }

    #notifToast {
      position: fixed;
      top: 80px;
      right: 24px;
      z-index: 9999;
      background: #171a25;
      border: 1px solid rgba(16, 185, 129, .3);
      border-radius: 14px;
      padding: 14px 18px;
      max-width: 320px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, .5);
      transform: translateX(120%);
      transition: transform .4s cubic-bezier(.34, 1.56, .64, 1);
    }

    #notifToast.show {
      transform: translateX(0);
    }

    .toast-icon {
      font-size: 22px;
      color: #10b981;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .toast-title {
      font-size: 13px;
      font-weight: 700;
      color: #f1f5f9;
    }

    .toast-msg {
      font-size: 12px;
      color: #94a3b8;
      margin-top: 2px;
    }

    @media (max-width: 991px) {
      .cc-sidebar {
        transform: translateX(-100%);
      }

      .cc-main {
        margin-left: 0;
      }

      .stats-strip {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</head>

<body>
  <%- include('../partials/flash') %>

  <!-- Sidebar -->
  <aside class="cc-sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">CareConnect</div>
      <div>
        <div class="brand-name">CareConnect</div>
        <div class="brand-sub">Admin Panel</div>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Main</div>
      <a href="/admin/dashboard" class="nav-item"><i class="bi bi-speedometer2"></i> Overview</a>
      <a href="/admin/profile" class="nav-item"><i class="bi bi-person-circle"></i> My Profile</a>
      <div class="nav-section-label">Management</div>
      <a href="/admin/appointments" class="nav-item active"><i class="bi bi-calendar-check"></i> Appointments <span
          class="nav-badge">
          <%= appointments.length %>
        </span></a>
      <a href="/admin/doctors" class="nav-item"><i class="bi bi-person-badge"></i> Doctors</a>
      <a href="/admin/patients" class="nav-item"><i class="bi bi-people"></i> Patients</a>
      <a href="/admin/clinics" class="nav-item"><i class="bi bi-hospital"></i> Clinics</a>
      <div class="nav-section-label">Reports</div>
      <a href="/admin/feedback" class="nav-item"><i class="bi bi-star-half"></i> Feedback</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="logout-btn"><i class="bi bi-box-arrow-right"></i> Sign Out</a>
    </div>
  </aside>

  <!-- Main -->
  <div class="cc-main">
    <div class="cc-topbar">
      <div>
        <div class="topbar-title">Manage Appointments</div>
        <div class="topbar-sub">Review bookings, update statuses & track outcomes</div>
      </div>
      <div class="topbar-actions">
        <div class="notif-btn" id="notifBell">
          <i class="bi bi-bell"></i>
          <span class="notif-dot" id="notifDot"></span>
        </div>
      </div>
    </div>

    <div class="cc-content">
      <!-- Stats -->
      <div class="stats-strip">
        <div class="stat-card">
          <div class="stat-icon emerald"><i class="bi bi-calendar-check"></i></div>
          <div>
            <div class="stat-val">
              <%= appointments.length %>
            </div>
            <div class="stat-label">Total Bookings</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon amber"><i class="bi bi-hourglass-split"></i></div>
          <div>
            <div class="stat-val">
              <%= appointments.filter(a=> a.status === 'pending').length %>
            </div>
            <div class="stat-label">Pending</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon indigo"><i class="bi bi-check2-circle"></i></div>
          <div>
            <div class="stat-val">
              <%= appointments.filter(a=> a.status === 'confirmed').length %>
            </div>
            <div class="stat-label">Confirmed</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon rose"><i class="bi bi-x-circle"></i></div>
          <div>
            <div class="stat-val">
              <%= appointments.filter(a=> a.status === 'cancelled').length %>
            </div>
            <div class="stat-label">Cancelled</div>
          </div>
        </div>
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs">
        <div class="filter-tab active" data-filter="all">All</div>
        <div class="filter-tab" data-filter="pending">Pending</div>
        <div class="filter-tab" data-filter="confirmed">Confirmed</div>
        <div class="filter-tab" data-filter="completed">Completed</div>
        <div class="filter-tab" data-filter="cancelled">Cancelled</div>
      </div>

      <!-- Table -->
      <div class="table-card">
        <div class="table-card-header">
          <div style="font-size:15px;font-weight:700;color:#f1f5f9;">Appointment Records</div>
          <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="apptSearch" placeholder="Search by patient or doctor…">
          </div>
        </div>
        <div class="table-responsive">
          <table class="cc-table" id="apptTable">
            <thead>
              <tr>
                <th>Patient</th>
                <th>Doctor</th>
                <th>Clinic & Dept</th>
                <th>Date & Slot</th>
                <th>Status</th>
                <th>Symptoms</th>
                <th>Update Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (appointments.length===0) { %>
                <tr>
                  <td colspan="7">
                    <div class="empty-state">
                      <i class="bi bi-calendar-x"></i>
                      <p>No appointments booked in the system yet.</p>
                    </div>
                  </td>
                </tr>
                <% } else { %>
                  <% appointments.forEach(appt=> { %>
                    <tr class="appt-row" data-status="<%= appt.status %>"
                      data-patient="<%= (appt.patient ? appt.patient.name : '').toLowerCase() %>"
                      data-doctor="<%= (appt.doctor ? appt.doctor.name : '').toLowerCase() %>">
                      <td>
                        <div class="person-name">
                          <%= appt.patient ? appt.patient.name : 'Unknown Patient' %>
                        </div>
                        <div class="person-sub"><i class="bi bi-telephone me-1"></i>
                          <%= appt.patient ? appt.patient.phone || 'N/A' : 'N/A' %>
                        </div>
                      </td>
                      <td>
                        <div class="person-name">
                          <%= appt.doctor ? appt.doctor.name : 'Unknown Doctor' %>
                        </div>
                        <div class="person-sub">
                          <%= appt.doctor ? appt.doctor.specialization || '—' : '—' %>
                        </div>
                      </td>
                      <td>
                        <div style="font-size:13px;font-weight:500;color:#e2e8f0;">
                          <%= appt.clinic ? appt.clinic.clinicName : '—' %>
                        </div>
                        <span class="cc-badge badge-dept mt-1">
                          <%= appt.department || 'General' %>
                        </span>
                      </td>
                      <td>
                        <div style="font-size:13px;font-weight:600;color:#f1f5f9;">
                          <%= new Date(appt.appointmentDate).toLocaleDateString("en-IN", { day: 'numeric' ,
                            month: 'short' , year: 'numeric' }) %>
                        </div>
                        <div class="person-sub"><i class="bi bi-clock me-1"></i>
                          <%= appt.appointmentTimeSlot %>
                        </div>
                      </td>
                      <td>
                        <span class="cc-badge badge-<%= appt.status %>">
                          <i class="bi bi-circle-fill" style="font-size:6px;"></i>
                          <%= appt.status %>
                        </span>
                      </td>
                      <td>
                        <div style="font-size:12px;color:#94a3b8;max-width:160px;">
                          <%= appt.symptoms || 'None reported' %>
                        </div>
                        <% if (appt.prescription) { %>
                          <div style="font-size:11px;color:#10b981;margin-top:4px;"><i
                              class="bi bi-file-medical me-1"></i>
                            <%= appt.prescription %>
                          </div>
                          <% } %>
                      </td>
                      <td>
                        <form action="/admin/appointments/update/<%= appt._id %>" method="POST">
                          <select name="status" class="status-select" onchange="this.form.submit()">
                            <option value="pending" <%=appt.status==='pending' ? 'selected' : '' %>>Pending</option>
                            <option value="confirmed" <%=appt.status==='confirmed' ? 'selected' : '' %>>Confirm</option>
                            <option value="completed" <%=appt.status==='completed' ? 'selected' : '' %>>Complete
                            </option>
                            <option value="cancelled" <%=appt.status==='cancelled' ? 'selected' : '' %>>Cancel</option>
                          </select>
                        </form>
                      </td>
                    </tr>
                    <% }) %>
                      <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="notifToast">
    <div class="toast-icon"><i class="bi bi-bell-fill"></i></div>
    <div>
      <div class="toast-title" id="toastTitle">Notification</div>
      <div class="toast-msg" id="toastMsg"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    // Filter tabs
    document.querySelectorAll('.filter-tab').forEach(tab => {
      tab.addEventListener('click', function () {
        document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        const filter = this.dataset.filter;
        document.querySelectorAll('.appt-row').forEach(row => {
          row.style.display = (filter === 'all' || row.dataset.status === filter) ? '' : 'none';
        });
      });
    });

    // Search
    document.getElementById('apptSearch').addEventListener('input', function () {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.appt-row').forEach(row => {
        const pat = row.dataset.patient || '';
        const doc = row.dataset.doctor || '';
        row.style.display = (pat.includes(q) || doc.includes(q)) ? '' : 'none';
      });
    });

    // Socket
    const socket = io();
    <% if (typeof admin !== 'undefined' && admin) { %>
      socket.emit('join', 'user_<%= admin._id %>');
    <% } %>

      function showToast(title, msg) {
        document.getElementById('toastTitle').textContent = title;
        document.getElementById('toastMsg').textContent = msg;
        document.getElementById('notifDot').style.display = 'block';
        const t = document.getElementById('notifToast');
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 5000);
      }
    socket.on('notification', data => showToast(data.title || 'Notification', data.message || ''));
  </script>
</body>

</html>