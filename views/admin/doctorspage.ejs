<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Doctors — CareConnect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    :root {
      --sidebar-w: 270px;
      --topbar-h: 70px;
    }
    body { background: #0f1117; font-family: 'Inter', sans-serif; color: #e2e8f0; min-height: 100vh; }

    /* ── Sidebar ── */
    .cc-sidebar {
      width: var(--sidebar-w); position: fixed; top: 0; left: 0; height: 100vh;
      background: linear-gradient(180deg, #13151f 0%, #0d0f18 100%);
      border-right: 1px solid rgba(255,255,255,.06);
      display: flex; flex-direction: column; z-index: 1000; overflow-y: auto;
    }
    .sidebar-brand {
      padding: 24px 22px 18px; border-bottom: 1px solid rgba(255,255,255,.06);
      display: flex; align-items: center; gap: 12px;
    }
    .brand-icon {
      width: 40px; height: 40px; border-radius: 12px;
      background: linear-gradient(135deg, #10b981, #6366f1);
      display: flex; align-items: center; justify-content: center; font-size: 18px;
    }
    .brand-name { font-size: 17px; font-weight: 800; color: #fff; letter-spacing: -.3px; }
    .brand-sub  { font-size: 10px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; }
    .sidebar-nav { padding: 18px 14px; flex: 1; }
    .nav-section-label {
      font-size: 9.5px; font-weight: 700; letter-spacing: 1.5px;
      color: #475569; text-transform: uppercase; padding: 0 8px; margin: 18px 0 8px;
    }
    .nav-item {
      display: flex; align-items: center; gap: 11px; padding: 10px 14px;
      border-radius: 10px; color: #94a3b8; text-decoration: none;
      font-size: 14px; font-weight: 500; transition: all .2s; margin-bottom: 2px;
    }
    .nav-item:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
    .nav-item.active { background: rgba(16,185,129,.12); color: #10b981; }
    .nav-item.active i { color: #10b981; }
    .nav-item i { font-size: 17px; width: 20px; text-align: center; }
    .nav-badge {
      margin-left: auto; background: #10b981; color: #fff;
      font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px;
    }
    .sidebar-footer {
      padding: 16px 14px; border-top: 1px solid rgba(255,255,255,.06);
    }
    .logout-btn {
      display: flex; align-items: center; gap: 10px; padding: 10px 14px;
      border-radius: 10px; color: #f87171; text-decoration: none;
      font-size: 14px; font-weight: 500; transition: background .2s;
    }
    .logout-btn:hover { background: rgba(248,113,113,.1); color: #f87171; }

    /* ── Main ── */
    .cc-main { margin-left: var(--sidebar-w); min-height: 100vh; background: #0f1117; }

    /* ── Topbar ── */
    .cc-topbar {
      height: var(--topbar-h); background: rgba(15,17,23,.95);
      backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,.06);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px; position: sticky; top: 0; z-index: 100;
    }
    .topbar-title { font-size: 19px; font-weight: 700; color: #f1f5f9; }
    .topbar-sub   { font-size: 12px; color: #64748b; margin-top: 1px; }
    .topbar-actions { display: flex; align-items: center; gap: 12px; }
    .notif-btn {
      width: 40px; height: 40px; border-radius: 10px;
      background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08);
      color: #94a3b8; display: flex; align-items: center; justify-content: center;
      font-size: 17px; cursor: pointer; transition: all .2s; position: relative;
    }
    .notif-btn:hover { background: rgba(255,255,255,.1); color: #e2e8f0; }
    .notif-dot {
      position: absolute; top: 7px; right: 7px;
      width: 8px; height: 8px; border-radius: 50%; background: #10b981;
      border: 2px solid #0f1117; display: none;
    }
    .add-btn {
      display: flex; align-items: center; gap: 8px; padding: 9px 18px;
      background: linear-gradient(135deg, #10b981, #059669);
      border: none; border-radius: 10px; color: #fff;
      font-size: 14px; font-weight: 600; cursor: pointer; transition: all .2s;
    }
    .add-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(16,185,129,.35); }

    /* ── Content Area ── */
    .cc-content { padding: 28px; }

    /* ── Stats Strip ── */
    .stats-strip { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 24px; }
    .stat-card {
      background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
      border-radius: 14px; padding: 18px 20px; display: flex; align-items: center; gap: 14px;
      transition: all .2s;
    }
    .stat-card:hover { background: rgba(255,255,255,.05); border-color: rgba(16,185,129,.2); }
    .stat-icon {
      width: 46px; height: 46px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;
    }
    .stat-icon.emerald { background: rgba(16,185,129,.15); color: #10b981; }
    .stat-icon.indigo  { background: rgba(99,102,241,.15);  color: #6366f1; }
    .stat-icon.amber   { background: rgba(245,158,11,.15);  color: #f59e0b; }
    .stat-icon.rose    { background: rgba(244,63,94,.15);   color: #f43f5e; }
    .stat-val  { font-size: 24px; font-weight: 800; color: #f1f5f9; line-height: 1; }
    .stat-label{ font-size: 12px; color: #64748b; margin-top: 3px; }

    /* ── Table Card ── */
    .table-card {
      background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
      border-radius: 16px; overflow: hidden;
    }
    .table-card-header {
      padding: 18px 22px; border-bottom: 1px solid rgba(255,255,255,.06);
      display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap;
    }
    .search-box {
      display: flex; align-items: center; gap: 9px; padding: 9px 14px;
      background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08);
      border-radius: 10px; width: 240px;
    }
    .search-box i { color: #64748b; font-size: 14px; }
    .search-box input {
      background: transparent; border: none; outline: none;
      color: #e2e8f0; font-size: 13px; width: 100%;
    }
    .search-box input::placeholder { color: #475569; }

    /* ── Table ── */
    .cc-table { width: 100%; border-collapse: collapse; }
    .cc-table thead tr {
      background: rgba(255,255,255,.03); border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .cc-table th {
      padding: 13px 18px; font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .8px; color: #64748b; white-space: nowrap;
    }
    .cc-table tbody tr {
      border-bottom: 1px solid rgba(255,255,255,.04); transition: background .15s;
    }
    .cc-table tbody tr:hover { background: rgba(255,255,255,.03); }
    .cc-table tbody tr:last-child { border-bottom: none; }
    .cc-table td { padding: 14px 18px; vertical-align: middle; }
    .doc-avatar {
      width: 42px; height: 42px; border-radius: 12px; object-fit: cover;
      border: 2px solid rgba(16,185,129,.3);
    }
    .doc-name  { font-size: 14px; font-weight: 600; color: #f1f5f9; }
    .doc-role  { font-size: 11px; color: #10b981; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; margin-top: 1px; }
    .contact-item { font-size: 12px; color: #94a3b8; display: flex; align-items: center; gap: 5px; margin-bottom: 2px; }
    .cc-badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; white-space: nowrap;
    }
    .badge-active   { background: rgba(16,185,129,.15); color: #10b981; border: 1px solid rgba(16,185,129,.25); }
    .badge-inactive { background: rgba(244,63,94,.12);  color: #f43f5e; border: 1px solid rgba(244,63,94,.2); }
    .badge-spec     { background: rgba(99,102,241,.12); color: #818cf8; border: 1px solid rgba(99,102,241,.2); }
    .action-btn {
      width: 34px; height: 34px; border-radius: 8px; border: 1px solid rgba(255,255,255,.08);
      background: rgba(255,255,255,.04); color: #94a3b8;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 14px; cursor: pointer; transition: all .2s; text-decoration: none;
    }
    .action-btn:hover { background: rgba(99,102,241,.15); color: #818cf8; border-color: rgba(99,102,241,.3); }
    .action-btn.danger:hover { background: rgba(244,63,94,.12); color: #f43f5e; border-color: rgba(244,63,94,.25); }
    .empty-state { padding: 60px; text-align: center; color: #475569; }
    .empty-state i { font-size: 48px; margin-bottom: 14px; display: block; color: #334155; }
    .empty-state p { font-size: 15px; }

    /* ── Modals ── */
    .cc-modal .modal-content {
      background: #171a25; border: 1px solid rgba(255,255,255,.1);
      border-radius: 18px; color: #e2e8f0;
    }
    .cc-modal .modal-header {
      border-bottom: 1px solid rgba(255,255,255,.07);
      padding: 22px 26px 18px;
    }
    .cc-modal .modal-title { font-size: 17px; font-weight: 700; color: #f1f5f9; }
    .cc-modal .btn-close { filter: invert(1) opacity(.5); }
    .cc-modal .modal-body { padding: 22px 26px; }
    .cc-modal .form-label { font-size: 12px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 7px; }
    .cc-modal .form-control, .cc-modal .form-select {
      background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
      border-radius: 10px; color: #e2e8f0; padding: 11px 14px; font-size: 14px;
    }
    .cc-modal .form-control:focus, .cc-modal .form-select:focus {
      background: rgba(255,255,255,.07); border-color: #10b981;
      box-shadow: 0 0 0 3px rgba(16,185,129,.15); color: #f1f5f9;
    }
    .cc-modal .form-control option, .cc-modal .form-select option { background: #171a25; }
    .cc-modal .btn-submit {
      width: 100%; padding: 13px; border: none; border-radius: 11px;
      background: linear-gradient(135deg, #10b981, #059669);
      color: #fff; font-size: 15px; font-weight: 700; cursor: pointer;
      transition: all .2s; margin-top: 6px;
    }
    .cc-modal .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(16,185,129,.35); }

    /* ── Notification toast ── */
    #notifToast {
      position: fixed; top: 80px; right: 24px; z-index: 9999;
      background: #171a25; border: 1px solid rgba(16,185,129,.3);
      border-radius: 14px; padding: 14px 18px; max-width: 320px;
      display: flex; align-items: flex-start; gap: 12px;
      box-shadow: 0 8px 32px rgba(0,0,0,.5); transform: translateX(120%);
      transition: transform .4s cubic-bezier(.34,1.56,.64,1);
    }
    #notifToast.show { transform: translateX(0); }
    .toast-icon { font-size: 22px; color: #10b981; flex-shrink: 0; margin-top: 2px; }
    .toast-title { font-size: 13px; font-weight: 700; color: #f1f5f9; }
    .toast-msg   { font-size: 12px; color: #94a3b8; margin-top: 2px; }

    @media (max-width: 991px) {
      .cc-sidebar { transform: translateX(-100%); }
      .cc-main { margin-left: 0; }
      .stats-strip { grid-template-columns: repeat(2,1fr); }
    }
  </style>
</head>
<body>
  <%- include('../partials/flash') %>

  <!-- Sidebar -->
  <aside class="cc-sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">🏥</div>
      <div>
        <div class="brand-name">CareConnect</div>
        <div class="brand-sub">Admin Panel</div>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Main</div>
      <a href="/admin/dashboard" class="nav-item"><i class="bi bi-speedometer2"></i> Overview</a>
      <a href="/admin/profile"   class="nav-item"><i class="bi bi-person-circle"></i> My Profile</a>

      <div class="nav-section-label">Management</div>
      <a href="/admin/appointments" class="nav-item"><i class="bi bi-calendar-check"></i> Appointments</a>
      <a href="/admin/doctors"      class="nav-item active"><i class="bi bi-person-badge"></i> Doctors <span class="nav-badge"><%= doctors.length %></span></a>
      <a href="/admin/patients"     class="nav-item"><i class="bi bi-people"></i> Patients</a>
      <a href="/admin/clinics"      class="nav-item"><i class="bi bi-hospital"></i> Clinics</a>

      <div class="nav-section-label">Reports</div>
      <a href="/admin/feedback" class="nav-item"><i class="bi bi-star-half"></i> Feedback</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="logout-btn"><i class="bi bi-box-arrow-right"></i> Sign Out</a>
    </div>
  </aside>

  <!-- Main -->
  <div class="cc-main">

    <!-- Topbar -->
    <div class="cc-topbar">
      <div>
        <div class="topbar-title">Manage Doctors</div>
        <div class="topbar-sub">Register, assign & manage clinic physicians</div>
      </div>
      <div class="topbar-actions">
        <div class="notif-btn" id="notifBell" title="Notifications">
          <i class="bi bi-bell"></i>
          <span class="notif-dot" id="notifDot"></span>
        </div>
        <button class="add-btn" data-bs-toggle="modal" data-bs-target="#addDoctorModal">
          <i class="bi bi-plus-lg"></i> Add Doctor
        </button>
      </div>
    </div>

    <!-- Content -->
    <div class="cc-content">

      <!-- Stats -->
      <div class="stats-strip">
        <div class="stat-card">
          <div class="stat-icon emerald"><i class="bi bi-person-badge"></i></div>
          <div>
            <div class="stat-val"><%= doctors.length %></div>
            <div class="stat-label">Total Doctors</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon indigo"><i class="bi bi-check-circle"></i></div>
          <div>
            <div class="stat-val"><%= doctors.filter(d => d.status === 'active').length %></div>
            <div class="stat-label">Active</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon amber"><i class="bi bi-hospital"></i></div>
          <div>
            <div class="stat-val"><%= doctors.filter(d => d.clinic).length %></div>
            <div class="stat-label">Assigned to Clinic</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon rose"><i class="bi bi-x-circle"></i></div>
          <div>
            <div class="stat-val"><%= doctors.filter(d => d.status !== 'active').length %></div>
            <div class="stat-label">Inactive</div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="table-card">
        <div class="table-card-header">
          <div style="font-size:15px;font-weight:700;color:#f1f5f9;">All Physicians</div>
          <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="doctorSearch" placeholder="Search by name or spec…">
          </div>
        </div>
        <div class="table-responsive">
          <table class="cc-table" id="doctorTable">
            <thead>
              <tr>
                <th>Doctor</th>
                <th>Contact</th>
                <th>Clinic</th>
                <th>Specialization</th>
                <th>Gender / Age</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (doctors.length === 0) { %>
                <tr>
                  <td colspan="7">
                    <div class="empty-state">
                      <i class="bi bi-person-badge"></i>
                      <p>No doctors registered yet. Add your first physician to get started.</p>
                    </div>
                  </td>
                </tr>
              <% } else { %>
                <% doctors.forEach(doctor => { %>
                  <tr class="doc-row" data-name="<%= doctor.name.toLowerCase() %>" data-spec="<%= (doctor.specialization || '').toLowerCase() %>">
                    <td>
                      <div style="display:flex;align-items:center;gap:12px;">
                        <img src="<%= doctor.profilePicture || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(doctor.name) + '&background=10b981&color=fff&size=80' %>"
                             alt="<%= doctor.name %>" class="doc-avatar">
                        <div>
                          <div class="doc-name"><%= doctor.name %></div>
                          <div class="doc-role"><%= doctor.role || 'Doctor' %></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <div class="contact-item"><i class="bi bi-envelope"></i> <%= doctor.email %></div>
                      <div class="contact-item"><i class="bi bi-telephone"></i> <%= doctor.phone || 'N/A' %></div>
                    </td>
                    <td><span style="color:#e2e8f0;font-size:13px;font-weight:500;"><%= doctor.clinic ? doctor.clinic.clinicName : '—' %></span></td>
                    <td><span class="cc-badge badge-spec"><%= doctor.specialization || 'General' %></span></td>
                    <td><span style="font-size:13px;color:#94a3b8;"><%= doctor.gender || 'N/A' %> / <%= doctor.age || '—' %> yrs</span></td>
                    <td>
                      <span class="cc-badge <%= doctor.status === 'active' ? 'badge-active' : 'badge-inactive' %>">
                        <i class="bi bi-circle-fill" style="font-size:6px;"></i>
                        <%= doctor.status === 'active' ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                    <td>
                      <div style="display:flex;gap:7px;">
                        <button class="action-btn" data-bs-toggle="modal" data-bs-target="#editDoctorModal<%= doctor._id %>" title="Edit"><i class="bi bi-pencil"></i></button>
                        <form action="/admin/doctors/delete/<%= doctor._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete Dr. <%= doctor.name %>? This cannot be undone.');">
                          <button type="submit" class="action-btn danger" title="Delete"><i class="bi bi-trash"></i></button>
                        </form>
                      </div>
                    </td>
                  </tr>

                  <!-- Edit Modal -->
                  <div class="modal fade cc-modal" id="editDoctorModal<%= doctor._id %>" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                      <div class="modal-content">
                        <div class="modal-header">
                          <h5 class="modal-title"><i class="bi bi-pencil-square me-2" style="color:#10b981;"></i>Edit Dr. <%= doctor.name %></h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                          <form action="/admin/doctors/edit/<%= doctor._id %>" method="POST" enctype="multipart/form-data">
                            <div class="row g-3">
                              <div class="col-md-6">
                                <label class="form-label">Full Name</label>
                                <input type="text" name="name" class="form-control" value="<%= doctor.name %>" required>
                              </div>
                              <div class="col-md-6">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control" value="<%= doctor.email %>" required>
                              </div>
                              <div class="col-md-6">
                                <label class="form-label">Phone Number</label>
                                <input type="text" name="phone" class="form-control" value="<%= doctor.phone %>">
                              </div>
                              <div class="col-md-6">
                                <label class="form-label">Assign Clinic</label>
                                <select name="clinic" class="form-select">
                                  <option value="">Select Clinic</option>
                                  <% clinics.forEach(c => { %>
                                    <option value="<%= c._id %>" <%= (doctor.clinic && (doctor.clinic._id || doctor.clinic).toString() === c._id.toString()) ? 'selected' : '' %>><%= c.clinicName %></option>
                                  <% }) %>
                                </select>
                              </div>
                              <div class="col-md-6">
                                <label class="form-label">Specialization</label>
                                <input type="text" name="specialization" class="form-control" value="<%= doctor.specialization %>" placeholder="e.g. Cardiology">
                              </div>
                              <div class="col-md-3">
                                <label class="form-label">Gender</label>
                                <select name="gender" class="form-select">
                                  <option value="Male"   <%= doctor.gender === 'Male'   ? 'selected' : '' %>>Male</option>
                                  <option value="Female" <%= doctor.gender === 'Female' ? 'selected' : '' %>>Female</option>
                                  <option value="Other"  <%= doctor.gender === 'Other'  ? 'selected' : '' %>>Other</option>
                                </select>
                              </div>
                              <div class="col-md-3">
                                <label class="form-label">Age</label>
                                <input type="number" name="age" class="form-control" value="<%= doctor.age %>" min="20" max="80">
                              </div>
                              <div class="col-12">
                                <label class="form-label">Profile Picture</label>
                                <input type="file" name="profilePicture" class="form-control" accept="image/*">
                              </div>
                              <div class="col-12">
                                <button type="submit" class="btn-submit">Save Changes</button>
                              </div>
                            </div>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Doctor Modal -->
  <div class="modal fade cc-modal" id="addDoctorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-person-plus me-2" style="color:#10b981;"></i>Register New Doctor</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form action="/admin/doctors/add" method="POST" enctype="multipart/form-data">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control" placeholder="Dr. Jane Smith" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="doctor@careconnect.com" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Temporary password" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Phone Number</label>
                <input type="text" name="phone" class="form-control" placeholder="+91 98765 43210">
              </div>
              <div class="col-md-6">
                <label class="form-label">Assign Clinic</label>
                <select name="clinic" class="form-select" required>
                  <option value="">Select Clinic</option>
                  <% clinics.forEach(c => { %>
                    <option value="<%= c._id %>"><%= c.clinicName %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Specialization</label>
                <input type="text" name="specialization" class="form-control" placeholder="e.g. Cardiology, Dental" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Gender</label>
                <select name="gender" class="form-select">
                  <option value="Male">Male</option>
                  <option value="Female">Female</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Age</label>
                <input type="number" name="age" class="form-control" placeholder="35" min="20" max="80">
              </div>
              <div class="col-12">
                <label class="form-label">Profile Picture</label>
                <input type="file" name="profilePicture" class="form-control" accept="image/*">
              </div>
              <div class="col-12">
                <button type="submit" class="btn-submit">Add Doctor</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Notification Toast -->
  <div id="notifToast">
    <div class="toast-icon"><i class="bi bi-bell-fill"></i></div>
    <div>
      <div class="toast-title" id="toastTitle">New Notification</div>
      <div class="toast-msg"  id="toastMsg"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    // Live search
    document.getElementById('doctorSearch').addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.doc-row').forEach(row => {
        const name = row.dataset.name || '';
        const spec = row.dataset.spec || '';
        row.style.display = (name.includes(q) || spec.includes(q)) ? '' : 'none';
      });
    });

    // Socket.io notifications
    const socket = io();
    const currentAdminId = "<%= typeof admin !== 'undefined' && admin ? admin._id : '' %>";
    if (currentAdminId) {
      socket.emit('join', 'user_' + currentAdminId);
    }

    function showToast(title, msg) {
      document.getElementById('toastTitle').textContent = title;
      document.getElementById('toastMsg').textContent   = msg;
      document.getElementById('notifDot').style.display = 'block';
      const t = document.getElementById('notifToast');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 5000);
    }

    socket.on('notification', data => showToast(data.title || 'Notification', data.message || ''));
    socket.on('connect_error', () => console.log('Socket connection unavailable'));
  </script>
</body>
</html>
